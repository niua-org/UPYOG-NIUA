    "micro-ui-internals/packages/svg-components",
    "micro-ui-internals/packages/modules/core",
    "micro-ui-internals/packages/modules/utilities",
    "micro-ui-internals/packages/modules/workbench"
  ],
  "engines": {
      "node": ">=22"
  },
  "dependencies": {
    "@upyog/workbench-ui-libraries": "1.8.1",
    "@upyog/workbench-ui-module-core": "1.8.2",
    "@upyog/workbench-ui-module-utilities": "1.0.0",
    "@upyog/workbench-ui-react-components": "1.0.0",
    "@nudmcdgnpm/workbench-ui-module-workbench": "^1.0.0",
    "@nudmcdgnpm/workbench-ui-svg-components": "1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "14.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react-router-dom": "6.28.0",
    "web-vitals": "1.1.2",
    "qrcode": "^1.5.4"
  },

  "devDependencies": {
    "http-proxy-middleware": "1.3.1",
    "lodash": "4.17.21",
    "npm-run-all": "4.1.5",
    "prettier": "2.1.2",
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.4.1",
    "vite-plugin-commonjs": "^0.10.4"
  },
  "scripts": {
    "start": "vite --config vite.config.js",
    "build": "vite build",
    "preview": "vite preview",
    "build:prepare": "./build.sh",
    "packages:build": "node scripts/package-builder.mjs",
    "packages:publish": "node scripts/package-publisher.mjs",
    "packages:release": "node scripts/package-builder.mjs && node scripts/package-publisher.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
