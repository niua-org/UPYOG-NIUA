{
  "name": "nudmcdg",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/modules/*",
    "example"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "yarn start:dev",
    "start:dev": "run-s build && run-p dev:**",

    "dev:example":    "cd example && yarn start",
    "dev:libraries":  "echo 'local source: libraries'",
    "dev:react-components": "echo 'local source: react-components'",
    "dev:common":     "echo 'local source: common'",
    "dev:core":       "echo 'local source: core'",
    "dev:sv":         "echo 'local source: sv'",
    "dev:engagement": "echo 'local source: engagement'",
    "devD:css":       "echo 'npm dist: css'",

    "build": "run-s build:css build:libraries build:react-components build:common build:core build:sv build:engagement",
    "build:css":        "cd packages/css && yarn build:prod",
    "build:libraries":  "cd packages/libraries && yarn build",
    "build:react-components": "cd packages/react-components && yarn build",
    "build:common":     "cd packages/modules/common && yarn build",
    "build:core":       "cd packages/modules/core && yarn build",
    "build:sv":         "cd packages/modules/sv && yarn build",
    "build:engagement": "cd packages/modules/engagement && yarn build",

    "deploy:jenkins": "./scripts/jenkins.sh"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5"
  }
}
