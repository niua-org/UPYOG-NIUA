{
  "name": "@nudmcdgnpm/cnd-css",
  "version": "1.0.0",
  "license": "MIT",
  "description": "CSS for CND UI & SV UI",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "vite build --watch",
    "build:prod": "vite build",
    "prepublish": "yarn build:prod"
  },
  "browserslist": [
    "> 3%",
    "last 2 versions"
  ],
  "style": "./dist/index.css",
  "exports": {
    ".": "./dist/index.css"
  },
  "dependencies": {
    "normalize.css": "8.0.1"
  },
  "devDependencies": {
    "sass": "^1.62.1",
    "autoprefixer": "10.4.14",
    "cssnano": "^6.0.1",
    "postcss": "8.4.31",
    "postcss-import": "15.1.0",
    "postcss-preset-env": "7.8.3",
    "postcss-scss": "3.0.5",
    "tailwindcss": "3.4.1",
    "vite": "^6.0.0"
  },
  "files": [
    "dist/index.css",
    "svg/**/*.svg",
    "img/**/*.png",
    "src/**/*.scss",
    "src/**/*.css"
  ],
  "keywords": [
    "upyog", "nudm", "dpg", "sv-ui", "core", "niua", "css"
  ]
}