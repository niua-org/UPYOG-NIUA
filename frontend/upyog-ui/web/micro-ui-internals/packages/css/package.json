{
  "name": "@nudmcdgnpm/upyog-css",
  "version": "2.1.0",
  "license": "MIT",
  "main": "dist/index.css",
  "author": "Shivank",
  "exports": {
    ".": "./dist/index.css",
    "./dist/index.css": "./dist/index.css",
    "./dist/index.min.css": "./dist/index.min.css"
  },
  "engines": {
    "node": ">=22"
  },
  "cssConfig": {
    "prefix": ""
  },
  "scripts": {
    "start": "gulp build",
    "build:prod": "NODE_ENV=production gulp build",
    "prepublish": "yarn build:prod",
    "deploy": "gulp && cp -R svg example && cp -R img example && gh-pages -d example"
  },
  "browserslist": [
    "> 3%",
    "last 2 versions"
  ],
  "style": "./dist/index.css",
  "dependencies": {
    "normalize.css": "8.0.1",
    "postcss-scss": "^4.0.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "cssnano": "^5.1.15",
    "gh-pages": "3.2.3",
    "gulp": "^4.0.2",
    "gulp-clean": "0.4.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-livereload": "4.0.2",
    "gulp-postcss": "9.0.1",
    "gulp-rename": "2.0.0",
    "gulp-sass": "^5.1.0",
    "postcss": "^8.4.26",
    "postcss-cli": "^10.1.0",
    "postcss-header": "2.0.0",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-prefixer": "2.1.3",
    "postcss-preset-env": "^7.8.3",
    "sass": "^1.70.0"
  },
  "files": [
    "dist/index.min.css",
    "dist/index.css",
    "svg/**/*.svg",
    "img/**/*.png",
    "src/**/*.scss",
    "src/**/*.css"
