<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPYOG Voice Assistant v2 - Telephone Call Experience</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Sans+Devanagari:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00d2ff;
            --secondary: #3a7bd5;
            --bg-dark: #0f172a;
            --chat-bg: rgba(30, 41, 59, 0.7);
            --user-bubble: #334155;
            --bot-bubble: linear-gradient(135deg, #3a7bd5 0%, #00d2ff 100%);
            --text-light: #f8fafc;
            --text-dim: #94a3b8;
            --success: #10b981;
            --warning: #f59e0b;
            --error: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', 'Noto Sans Devanagari', sans-serif;
        }

        body {
            background: radial-gradient(circle at top left, #1e293b, #0f172a);
            color: var(--text-light);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 10;
        }

        header h1 {
            font-size: 1.25rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        header h1 span {
            font-size: 1.5rem;
        }

        .lang-toggle {
            display: flex;
            gap: 0.25rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0.5rem;
            padding: 0.25rem;
        }

        .lang-btn {
            padding: 0.4rem 0.8rem;
            border: none;
            background: transparent;
            color: var(--text-dim);
            cursor: pointer;
            border-radius: 0.35rem;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .lang-btn.active {
            background: var(--primary);
            color: var(--bg-dark);
            font-weight: 600;
        }

        #chat-container {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            scroll-behavior: smooth;
        }

        .message {
            max-width: 80%;
            padding: 1rem 1.25rem;
            border-radius: 1.25rem;
            font-size: 0.95rem;
            line-height: 1.5;
            position: relative;
            animation: fadeIn 0.3s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user-message {
            align-self: flex-end;
            background: var(--user-bubble);
            border-bottom-right-radius: 0.25rem;
            color: white;
        }

        .bot-message {
            align-self: flex-start;
            background: var(--bot-bubble);
            border-bottom-left-radius: 0.25rem;
            box-shadow: 0 4px 15px rgba(0, 210, 255, 0.2);
        }

        .message-time {
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.5);
            margin-top: 0.5rem;
        }

        .status-bar {
            padding: 0.75rem 1.5rem;
            background: rgba(15, 23, 42, 0.95);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.9rem;
        }

        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--text-dim);
        }

        .status-dot.idle { background: var(--text-dim); }
        .status-dot.listening {
            background: var(--success);
            animation: pulse-green 1.5s infinite;
        }
        .status-dot.processing {
            background: var(--warning);
            animation: spin 1s linear infinite;
        }
        .status-dot.speaking {
            background: var(--primary);
            animation: pulse-blue 1s infinite;
        }

        @keyframes pulse-green {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.7; transform: scale(1.2); }
        }

        @keyframes pulse-blue {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.1); }
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .session-btn {
            padding: 0.6rem 1.2rem;
            border: none;
            border-radius: 2rem;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .session-btn.start {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            color: white;
        }

        .session-btn.end {
            background: var(--error);
            color: white;
        }

        .session-btn:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

        .settings-toggle {
            position: fixed;
            bottom: 80px;
            right: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: var(--text-dim);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            z-index: 100;
            transition: all 0.3s;
        }

        .settings-toggle:hover {
            background: rgba(255, 255, 255, 0.2);
            color: var(--text-light);
        }

        .settings-panel {
            position: fixed;
            bottom: 130px;
            right: 20px;
            background: rgba(30, 41, 59, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 1rem;
            width: 280px;
            z-index: 100;
            display: none;
            backdrop-filter: blur(10px);
        }

        .settings-panel.show {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }

        .settings-panel h3 {
            font-size: 0.9rem;
            margin-bottom: 1rem;
            color: var(--primary);
        }

        .setting-item {
            margin-bottom: 1rem;
        }

        .setting-item label {
            display: block;
            font-size: 0.8rem;
            color: var(--text-dim);
            margin-bottom: 0.5rem;
        }

        .setting-item input[type="range"] {
            width: 100%;
            accent-color: var(--primary);
        }

        .setting-item select {
            width: 100%;
            padding: 0.5rem;
            border-radius: 0.5rem;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: var(--text-light);
            font-size: 0.85rem;
        }

        .interim-text {
            position: fixed;
            bottom: 85px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(99, 102, 241, 0.9);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            font-size: 0.85rem;
            display: none;
            z-index: 50;
        }

        .interim-text.show {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }

        .hint-text {
            font-size: 0.75rem;
            color: var(--text-dim);
            margin-top: 0.25rem;
        }

        /* Text Input Area */
        .input-area {
            padding: 0.75rem 1rem;
            background: rgba(15, 23, 42, 0.95);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .input-area input[type="text"] {
            flex: 1;
            padding: 0.75rem 1rem;
            border-radius: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.15);
            background: rgba(30, 41, 59, 0.8);
            color: var(--text-light);
            font-size: 0.95rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-area input[type="text"]:focus {
            border-color: var(--primary);
        }

        .input-area input[type="text"]::placeholder {
            color: var(--text-dim);
        }

        .send-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg, #3a7bd5 0%, #00d2ff 100%);
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s, filter 0.2s;
        }

        .send-btn:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

        .send-btn:active {
            transform: scale(0.95);
        }
    </style>
</head>

<body>
    <header>
        <h1><span>🏛</span> UPYOG Assistant</h1>
        <div class="lang-toggle">
            <button class="lang-btn" data-lang="en">EN</button>
            <button class="lang-btn" data-lang="hi">HI</button>
            <button class="lang-btn active" data-lang="auto">Auto</button>
        </div>
    </header>

    <div id="chat-container">
        <div class="message bot-message">
            Namaste! I am your UPYOG assistant. You can ask me questions about government services, or say "I want to file a complaint" to register a grievance. Click "Start Session" for voice conversation or type your message below.
        </div>
    </div>

    <div class="interim-text" id="interim-display"></div>

    <div class="status-bar">
        <div class="status-indicator">
            <div class="status-dot idle" id="status-dot"></div>
            <span id="status-text">Ready</span>
        </div>
        <button class="session-btn start" id="session-toggle-btn">Start Session</button>
    </div>

    <!-- Text Input Area -->
    <div class="input-area">
        <input type="text" id="text-input" placeholder="Type your message here..." autocomplete="off">
        <button id="send-text-btn" class="send-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
        </button>
    </div>

    <button class="settings-toggle" id="settings-toggle">⚙</button>

    <div class="settings-panel" id="settings-panel">
        <h3>Settings</h3>
        <div class="setting-item">
            <label>Barge-in Sensitivity: <span id="sensitivity-value">0.02</span></label>
            <input type="range" id="barge-sensitivity" min="0.01" max="0.05" step="0.01" value="0.02">
            <div class="hint-text">Lower = more sensitive</div>
        </div>
        <div class="setting-item">
            <label>Language Preference</label>
            <select id="lang-preference">
                <option value="auto">Auto Detect</option>
                <option value="hi">Force Hindi</option>
                <option value="en">Force English</option>
            </select>
        </div>
    </div>

    <script>
        // ============== STATE ==============
        const States = {
            IDLE: 'IDLE',
            LISTENING: 'LISTENING',
            PROCESSING: 'PROCESSING',
            SPEAKING: 'SPEAKING'
        };

        let currentState = States.IDLE;
        let sessionActive = false;
        let currentLang = 'auto';
        let history = [];  // Conversation memory
        let recognition = null;
        let currentAudio = null;
        let conversationSessionId = 'upyog_' + Math.random().toString(36).substr(2, 9);
        let currentFetch = null;

        // FIX B: Turn tracking for recognition recreation
        let turnCount = 0;
        let lastDetectedLang = 'en';
        let currentTranscript = '';
        let finalTranscript = '';
        let silenceTimer = null;
        let forceTimer = null;

        // FIX B: Constants for smarter sending
        const MIN_WORDS_TO_SEND = 3;
        const SILENCE_WAIT_MS = 2500;
        const FORCE_SEND_MS = 8000;
        const MAX_HISTORY_IN_MEMORY = 20;
        const HISTORY_TO_BACKEND = 8;

        // FIX C: Audio pool for cleanup
        const audioPool = [];

        // Barge-in monitoring
        let analyser = null;
        let micStream = null;
        let bargeInThreshold = 0.02;
        let voiceFrames = 0;

        // DOM elements
        const chatContainer = document.getElementById('chat-container');
        const statusDot = document.getElementById('status-dot');
        const statusText = document.getElementById('status-text');
        const sessionBtn = document.getElementById('session-toggle-btn');
        const interimDisplay = document.getElementById('interim-display');
        const settingsToggle = document.getElementById('settings-toggle');
        const settingsPanel = document.getElementById('settings-panel');
        const bargeSensitivity = document.getElementById('barge-sensitivity');
        const sensitivityValue = document.getElementById('sensitivity-value');

        // API URL
        // Use dynamic URL for both local testing and Nginx proxy compatibility
        let API_URL = window.location.origin;
        if (window.location.pathname.includes('/upyog-voice')) {
            API_URL += '/upyog-voice';
        }
        console.log('UPYOG Voice v2 initialized. Target:', API_URL);

        // ============== STATE MACHINE ==============
        function setState(newState) {
            currentState = newState;
            statusDot.className = 'status-dot ' + newState.toLowerCase();

            const stateText = {
                'IDLE': 'Ready',
                'LISTENING': 'Listening...',
                'PROCESSING': 'Thinking...',
                'SPEAKING': 'Speaking...'
            };
            statusText.innerText = stateText[newState];
        }

        // ============== HINGLISH DETECTION ==============
        const HINDI_PATTERNS = [
            /\b(kya|kaise|kahan|kab|kyun|kon|kitna|kitne)\b/i,
            /\b(hai|hain|tha|the|thi|hoga|hogi|hoge)\b/i,
            /\b(mujhe|aapko|humko|tumhe|unhe)\b/i,
            /\b(batao|bataye|bataiye|samjhao|dikhao)\b/i,
            /\b(nahi|nahin|mat|na)\b/i,
            /\b(aur|ya|lekin|toh|ki|ke|ka|ko)\b/i,
            /\b(please|plz)\s+(batao|karo|dijiye|karein)\b/i
        ];

        function detectHinglish(text) {
            return HINDI_PATTERNS.some(p => p.test(text));
        }

        // ============== LANGUAGE TOGGLE ==============
        document.querySelectorAll('.lang-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentLang = btn.dataset.lang;
            });
        });

        // ============== SETTINGS PANEL ==============
        settingsToggle.addEventListener('click', () => {
            settingsPanel.classList.toggle('show');
        });

        bargeSensitivity.addEventListener('input', (e) => {
            bargeInThreshold = parseFloat(e.target.value);
            sensitivityValue.innerText = bargeInThreshold.toFixed(2);
        });

        document.getElementById('lang-preference').addEventListener('change', (e) => {
            currentLang = e.target.value;
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.lang === currentLang);
            });
        });

        // ============== MESSAGE DISPLAY ==============
        function addMessageToUI(text, side, mode) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${side === 'user' ? 'user-message' : 'bot-message'}`;
            msgDiv.innerText = text;

            // Style based on mode
            if (mode === 'grievance_offered') {
                // Amber/orange styling - this is an action prompt
                msgDiv.style.borderLeft = '3px solid #F59E0B';
                msgDiv.style.background = 'rgba(245, 158, 11, 0.1)';
            } else if (mode === 'grievance_collecting') {
                // Orange left border - grievance in progress
                msgDiv.style.borderLeft = '3px solid #FF6B35';
            } else if (mode === 'grievance') {
                msgDiv.style.borderLeft = '3px solid #FF6B35';
            }

            chatContainer.appendChild(msgDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
            console.log(`[${side}] ${text}`);
        }

        // ============== SPEECH RECOGNITION (FIX A & B) ==============

        // FIX A: Destroy recognition object completely
        function destroyRecognition() {
            if (recognition) {
                recognition.onstart = null;
                recognition.onresult = null;
                recognition.onspeechend = null;
                recognition.onend = null;
                recognition.onerror = null;
                try { recognition.abort(); } catch(e) {}
                recognition = null;
            }
        }

        // FIX A: Create recognition with language parameter
        function createRecognition(lang) {
            destroyRecognition();

            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SR) {
                alert('Speech recognition not supported in this browser');
                return null;
            }

            recognition = new SR();
            recognition.continuous = true;
            recognition.interimResults = true;
            recognition.maxAlternatives = 1;
            recognition.lang = lang === 'hi' ? 'hi-IN' : 'en-IN';

            recognition.onstart = () => {
                console.log('✅ Recognition started, lang:', recognition.lang);
                setState(States.LISTENING);
            };

            recognition.onresult = handleResult;
            recognition.onspeechend = handleSpeechEnd;

            recognition.onend = () => {
                console.log('Recognition ended, state:', currentState, 'session:', sessionActive);
                if (sessionActive && currentState === States.LISTENING) {
                    setTimeout(() => {
                        if (sessionActive && recognition) {
                            try { recognition.start(); } catch(e) {
                                console.warn('onend restart failed:', e.name);
                            }
                        }
                    }, 100);
                }
            };

            recognition.onerror = (e) => {
                console.error('❌ Recognition error:', e.error);
                if (e.error === 'no-speech' || e.error === 'aborted') return;

                setTimeout(() => {
                    if (sessionActive) {
                        console.log('Recreating after error:', e.error);
                        createRecognition(lastDetectedLang);
                        try { recognition.start(); } catch(e) {}
                    }
                }, 500);
            };

            return recognition;
        }

        function createAndStartRecognition() {
            const lang = lastDetectedLang || 'en';
            console.log('Creating recognition with lang:', lang);
            createRecognition(lang);
            if (recognition) {
                try {
                    recognition.start();
                    console.log('Recognition started successfully');
                } catch(e) {
                    console.error('Failed to start recognition:', e);
                }
            } else {
                console.error('Recognition object not created');
            }
        }

        // FIX B: Handle result with silence timer
        function handleResult(event) {
            clearTimeout(silenceTimer);
            clearTimeout(forceTimer);

            let interim = '';
            let newFinal = '';

            for (let i = event.resultIndex; i < event.results.length; i++) {
                const transcript = event.results[i][0].transcript;
                if (event.results[i].isFinal) {
                    newFinal += transcript + ' ';
                } else {
                    interim += transcript;
                }
            }

            if (newFinal) {
                finalTranscript += newFinal;
            }

            // Show interim in UI so user sees what's being captured
            const displayText = finalTranscript + interim;
            if (displayText) {
                interimDisplay.innerText = '🎤 ' + displayText;
                interimDisplay.classList.add('show');
            }

            // Set silence timer — send after 2.5s of no new speech
            const textToSend = finalTranscript.trim() || interim.trim();
            if (textToSend) {
                silenceTimer = setTimeout(() => {
                    attemptSend(textToSend);
                }, SILENCE_WAIT_MS);

                // Also set a maximum wait timer
                if (!forceTimer) {
                    forceTimer = setTimeout(() => {
                        if (textToSend) attemptSend(textToSend);
                    }, FORCE_SEND_MS);
                }
            }
        }

        // FIX B: Handle speech end - do NOT send immediately
        function handleSpeechEnd() {
            console.log('Speech end detected — waiting for silence timer');
            // The silence timer in handleResult will handle sending
        }

        // FIX B: Attempt send with word gate
        function attemptSend(text) {
            clearTimeout(silenceTimer);
            clearTimeout(forceTimer);

            const words = text.trim().split(/\s+/);

            // Gate: don't send if too short (prevents partial captures)
            if (words.length < MIN_WORDS_TO_SEND) {
                console.log('Too short to send:', text, '— waiting for more');
                return;
            }

            // Pause recognition while processing
            try { recognition.stop(); } catch(e) {}

            finalTranscript = '';
            currentTranscript = '';

            sendQuery(text.trim());
        }

        // FIX B & C: On turn complete - recreate recognition every 5 turns + cleanup
        function onTurnComplete() {
            turnCount++;
            finalTranscript = '';
            currentTranscript = '';
            clearTimeout(silenceTimer);
            clearTimeout(forceTimer);
            silenceTimer = null;
            forceTimer = null;

            if (!sessionActive) return;

            // Recreate every 5 turns to prevent browser engine degradation
            if (turnCount % 5 === 0) {
                console.log('Turn', turnCount, '— scheduled recreation of recognition');
                destroyRecognition();
                createRecognition(lastDetectedLang);
            }

            // Resume listening
            if (recognition) {
                try {
                    recognition.start();
                    setState(States.LISTENING);
                    console.log('Turn complete — listening resumed');
                } catch(e) {
                    if (e.name === 'InvalidStateError') {
                        // Already running — that's fine
                        setState(States.LISTENING);
                    } else {
                        // Real error — recreate
                        console.error('onTurnComplete restart error:', e);
                        setTimeout(() => {
                            if (sessionActive) {
                                destroyRecognition();
                                createRecognition(lastDetectedLang);
                                recognition.start();
                                setState(States.LISTENING);
                            }
                        }, 300);
                    }
                }
            }
        }

        // ============== BARGE-IN MONITORING ==============
        async function startBargeInMonitor() {
            try {
                micStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                const audioCtx = new AudioContext();
                const source = audioCtx.createMediaStreamSource(micStream);
                analyser = audioCtx.createAnalyser();
                analyser.fftSize = 512;
                source.connect(analyser);

                const buffer = new Float32Array(analyser.fftSize);

                function checkVolume() {
                    if (!sessionActive) return;

                    analyser.getFloatTimeDomainData(buffer);
                    const rms = Math.sqrt(buffer.reduce((s, v) => s + v * v, 0) / buffer.length);

                    // ONLY check for barge-in during SPEAKING state
                    // Do NOT trigger during LISTENING or PROCESSING
                    if (currentState === States.SPEAKING) {
                        if (rms > bargeInThreshold) {
                            voiceFrames++;
                            if (voiceFrames > 8) {  // ~300ms of sustained voice
                                triggerBargeIn();
                                voiceFrames = 0;
                                requestAnimationFrame(checkVolume);
                                return;
                            }
                        } else {
                            voiceFrames = 0;
                        }
                    } else {
                        // Reset frame counter when not in SPEAKING state
                        voiceFrames = 0;
                    }

                    requestAnimationFrame(checkVolume);
                }
                checkVolume();
            } catch(e) {
                console.error('Barge-in monitor error:', e);
            }
        }

        function triggerBargeIn() {
            console.log('Barge-in triggered — full reset starting');

            // Step 1: Stop current audio immediately
            if (currentAudio) {
                currentAudio.pause();
                currentAudio.currentTime = 0;
                currentAudio.src = '';
                currentAudio = null;
            }

            // Step 2: Abort any pending backend fetch
            if (currentFetch) {
                currentFetch.abort();
                currentFetch = null;
            }

            // Step 3: Signal backend to stop TTS generation
            fetch('/stop', { method: 'POST' }).catch(() => {});

            // Step 4: Clear all transcript buffers
            finalTranscript = '';
            currentTranscript = '';

            // Step 5: Clear all pending timers
            clearTimeout(silenceTimer);
            clearTimeout(forceTimer);
            silenceTimer = null;
            forceTimer = null;

            // Step 6: Kill the current recognition instance completely
            // (it is in a broken/zombie state after barge-in)
            destroyRecognition();

            // Step 7: Update state to LISTENING
            setState('LISTENING');
            clearInterimDisplay();

            // Step 8: Recreate fresh recognition and start listening
            // Small delay (300ms) lets the browser audio context settle
            // after the abrupt audio stop — prevents echo/feedback capture
            setTimeout(() => {
                if (sessionActive) {
                    console.log('Barge-in: restarting fresh recognition');
                    createRecognition(lastDetectedLang);
                    try {
                        recognition.start();
                        console.log('Barge-in: recognition restarted successfully');
                    } catch(e) {
                        console.error('Barge-in: failed to restart recognition:', e);
                        // Try once more after another short delay
                        setTimeout(() => {
                            if (sessionActive) {
                                createRecognition(lastDetectedLang);
                                recognition.start();
                            }
                        }, 300);
                    }
                }
            }, 300);
        }

        function clearInterimDisplay() {
            if (interimDisplay) {
                interimDisplay.classList.remove('show');
                interimDisplay.innerText = '';
            }
        }

        // ============== SEND QUERY (FIX C: Memory management) ==============
        async function sendQuery(transcript) {
            if (!transcript.trim()) return;

            setState(States.PROCESSING);
            interimDisplay.classList.remove('show');
            interimDisplay.innerText = '';
            interimDisplay.style.opacity = '0';

            // Abort any pending previous request
            if (currentFetch) {
                currentFetch.abort();
                currentFetch = null;
            }

            console.log(`Sending: "${transcript}" (backend will detect language)`);

            // FIX C: Cap history to prevent growing payload
            history.push({ role: 'user', content: transcript });
            if (history.length > MAX_HISTORY_IN_MEMORY) {
                history.splice(0, history.length - MAX_HISTORY_IN_MEMORY);
            }
            addMessageToUI(transcript, 'user');

            currentFetch = new AbortController();

            try {
                const response = await fetch(`${API_URL}/chat`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        query: transcript,
                        session_id: conversationSessionId,
                        history: history.slice(-HISTORY_TO_BACKEND)  // Only last 8 turns to backend
                    }),
                    signal: currentFetch.signal
                });

                const data = await response.json();
                currentFetch = null;

                // Handle grievance mode indicator
                if (data.mode === 'grievance' || data.mode === 'grievance_collecting' || data.mode === 'grievance_offered') {
                    const statusBar = document.querySelector('.status-bar');
                    statusBar.style.borderLeft = '4px solid #FF6B35';
                    console.log('Grievance mode active:', data.mode);
                } else {
                    const statusBar = document.querySelector('.status-bar');
                    statusBar.style.borderLeft = '';
                }

                if (data.error) {
                    console.error('Error:', data.error);
                    addMessageToUI('Sorry, an error occurred.', 'bot', null);
                    setState(States.LISTENING);
                    onTurnComplete();
                    return;
                }

                // Backend returns detected language - use for NEXT turn's speech recognition
                const detectedLang = data.lang || 'en';
                const detectedScript = data.detected_script || 'unknown';
                console.log(`Backend detected: lang=${detectedLang}, script=${detectedScript}`);

                // FIX B: Update lastDetectedLang for recognition recreation
                lastDetectedLang = detectedLang;

                // Update speech recognition language for next turn
                if (recognition) {
                    recognition.lang = detectedLang === 'hi' ? 'hi-IN' : 'en-IN';
                    console.log(`Speech recognition language updated to: ${recognition.lang}`);
                }

                // Add to history (with detected lang for TTS reference if needed)
                history.push({ role: 'assistant', content: data.response, lang: detectedLang });
                addMessageToUI(data.response, 'bot', data.mode);

                // Show detected script for debugging (small indicator)
                if (detectedScript !== 'unknown') {
                    const scriptIndicator = document.createElement('div');
                    scriptIndicator.style.cssText = 'font-size: 0.65rem; color: rgba(255,255,255,0.5); margin-top: 4px;';
                    scriptIndicator.innerText = `Detected: ${detectedScript}`;
                    // Could append to last message if desired
                }

                // Play audio
                if (data.audio) {
                    playAudio(data.audio);
                } else {
                    setState(States.LISTENING);
                    onTurnComplete();
                }

            } catch (error) {
                if (error.name !== 'AbortError') {
                    console.error('Fetch error:', error);
                    addMessageToUI('Sorry, connection failed.', 'bot', null);
                }
                setState(States.LISTENING);
                currentFetch = null;
                onTurnComplete();
            }
        }

        // ============== AUDIO PLAYBACK (FIX C: Blob URL cleanup) ==============
        async function playAudio(base64) {
            setState(States.SPEAKING);

            try {
                // FIX C: Stop and destroy previous audio completely
                if (currentAudio) {
                    currentAudio.pause();
                    currentAudio.src = '';
                    currentAudio.load();
                    currentAudio = null;
                }

                // FIX C: Revoke old blob URLs to free memory
                audioPool.forEach(url => {
                    try { URL.revokeObjectURL(url); } catch(e) {}
                });
                audioPool.length = 0;

                const mimeType = base64.startsWith('//O') || base64.startsWith('SUQz') ? 'audio/mp3' : 'audio/wav';

                // FIX C: Use blob URL for better memory management
                const byteCharacters = atob(base64);
                const byteNumbers = new Array(byteCharacters.length);
                for (let i = 0; i < byteCharacters.length; i++) {
                    byteNumbers[i] = byteCharacters.charCodeAt(i);
                }
                const byteArray = new Uint8Array(byteNumbers);
                const blob = new Blob([byteArray], { type: mimeType });
                const url = URL.createObjectURL(blob);
                audioPool.push(url);

                currentAudio = new Audio(url);

                currentAudio.onended = () => {
                    URL.revokeObjectURL(url);
                    currentAudio = null;
                    setState(States.LISTENING);
                    onTurnComplete();
                };

                currentAudio.onerror = () => {
                    console.error('Audio playback error');
                    URL.revokeObjectURL(url);
                    currentAudio = null;
                    setState(States.LISTENING);
                    onTurnComplete();
                };

                await currentAudio.play();
            } catch(e) {
                console.error('Audio error:', e);
                setState(States.LISTENING);
                onTurnComplete();
            }
        }

        // ============== SESSION MANAGEMENT ==============
        sessionBtn.addEventListener('click', async () => {
            if (sessionActive) {
                // End session
                sessionActive = false;
                sessionBtn.innerText = 'Start Session';
                sessionBtn.classList.remove('end');
                sessionBtn.classList.add('start');

                clearTimeout(silenceTimer);
                clearTimeout(forceTimer);

                destroyRecognition();

                if (currentAudio) {
                    currentAudio.pause();
                    currentAudio.src = '';
                    currentAudio = null;
                }

                if (micStream) {
                    micStream.getTracks().forEach(t => t.stop());
                    micStream = null;
                }

                setState(States.IDLE);
                console.log('Session ended');

            } else {
                // Start session
                sessionActive = true;
                sessionBtn.innerText = 'End Session';
                sessionBtn.classList.remove('start');
                sessionBtn.classList.add('end');

                // Reset state
                turnCount = 0;
                finalTranscript = '';
                currentTranscript = '';

                try {
                    // Start continuous listening
                    console.log('Starting recognition...');
                    createAndStartRecognition();

                    // Start barge-in monitor
                    console.log('Starting barge-in monitor...');
                    startBargeInMonitor();

                    setState(States.LISTENING);
                    console.log('Session started successfully');
                } catch(e) {
                    console.error('Failed to start session:', e);
                    sessionActive = false;
                    sessionBtn.innerText = 'Start Session';
                    sessionBtn.classList.remove('end');
                    sessionBtn.classList.add('start');
                    alert('Could not start voice session. Please check microphone permissions.');
                }
            }
        });

        // Keyboard shortcut
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space' && sessionActive) {
                e.preventDefault();
            }
        });

        // ============== TEXT INPUT HANDLING ==============
        const textInput = document.getElementById('text-input');
        const sendTextBtn = document.getElementById('send-text-btn');

        function handleTextSubmit() {
            const text = textInput.value.trim();
            if (!text) return;

            // Send the typed text (backend will detect language per-turn)
            sendQuery(text);
            textInput.value = '';
        }

        // Send on button click
        sendTextBtn.addEventListener('click', handleTextSubmit);

        // Send on Enter key
        textInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                handleTextSubmit();
            }
        });

        console.log('UPYOG Voice v2 loaded successfully');
    </script>
</body>
</html>