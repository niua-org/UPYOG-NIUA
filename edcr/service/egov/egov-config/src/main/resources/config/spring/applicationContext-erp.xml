<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/tx
           http://www.springframework.org/schema/tx/spring-tx.xsd">

    <!--
    Enables Spring's annotation-driven transaction management for methods
    annotated with @Transactional.

    proxy-target-class="false" instructs Spring to use JDK Dynamic Proxies
    instead of CGLIB proxies.

    JDK Dynamic Proxy:
    - Default behavior when target class implements an interface.
    - Creates proxies based on interfaces.
    - Lower overhead and preferred when service interfaces are available.

    CGLIB Proxy (proxy-target-class="true"):
    - Creates subclass-based proxies.
    - Can proxy classes that do not implement interfaces.
    - Requires additional bytecode generation and cannot proxy final classes
      or final methods.

    This configuration is required to ensure transactional boundaries are
    applied correctly to ERP service layer methods after the Spring upgrade.
    -->
    <tx:annotation-driven proxy-target-class="true"/>

    <bean name="erpApplicationContext"
          class="org.springframework.context.support.ClassPathXmlApplicationContext">
        <constructor-arg>
            <list>
                <value>classpath*:config/spring/applicationContext-security.xml</value>
                <value>classpath*:config/spring/applicationContext-*-services.xml</value>
            </list>
        </constructor-arg>
    </bean>

</beans>