<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <context:property-placeholder location="classpath:config/application-config.properties"/>
    <!-- ERP-equivalent security beans (parent ContextLoader chain is not supplying them to this WAR) -->
    <import resource="classpath*:config/spring/applicationContext-security.xml"/>
    <import resource="applicationSecurityContext-egi.xml"/>

    <!--Scan entire org.egov package hierarchy to ensure core infrastructure beans
    (e.g., ICityService, cities, ApplicationCoreFilter dependencies) are discovered.
    Restricting the scan scope causes NoSuchBeanDefinitionException during startup.-->
    <context:component-scan base-package="org.egov">
        <context:exclude-filter type="regex" expression="org\.egov\.edcr\..*"/>
        <context:exclude-filter type="regex" expression="org\.egov\.commons\..*"/>
        <context:exclude-filter type="annotation" expression="org.springframework.stereotype.Controller"/>
    </context:component-scan>

    <!-- web.xml must use DelegatingFilterProxy for these so @Autowired / @Resource are applied -->
    <bean id="applicationCoreFilter" class="org.egov.infra.web.filter.ApplicationCoreFilter"/>
    <bean id="applicationTenantResolverFilter" class="org.egov.infra.web.filter.ApplicationTenantResolverFilter"/>

    <bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
        <property name="maxUploadSize" value="${max.file.upload.size}"/>
        <property name="maxInMemorySize" value="${max.file.inmemory.size}"/>
    </bean>

</beans>
