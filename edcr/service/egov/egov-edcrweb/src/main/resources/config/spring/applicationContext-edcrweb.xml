<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <import resource="applicationSecurityContext-edcr.xml"/>
    <import resource="classpath*:config/spring/applicationContext-infra-services.xml"/>

    <context:property-placeholder/>

    <!--
    Scans Spring-managed components from the specified packages and
    registers them as beans in the application context.

    Controllers and RestControllers are explicitly excluded because
    they are loaded through the web application context and should not
    be part of the root application context.
    -->
    <!-- Scan everything needed — RepositoryConfiguration stays, but fixed with LAZY below -->
    <context:component-scan base-package="org.egov.edcr, org.egov.commons, org.egov.infra">
        <context:exclude-filter type="annotation"
            expression="org.springframework.stereotype.Controller"/>
        <context:exclude-filter type="annotation"
            expression="org.springframework.web.bind.annotation.RestController"/>
    </context:component-scan>

    <context:component-scan base-package="org.egov.edcr.web.controller.rest">
        <context:exclude-filter type="annotation" expression="org.springframework.web.bind.annotation.RestController"/>
    </context:component-scan>

    <bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
        <property name="maxUploadSize" value="104857600"/>
        <property name="maxInMemorySize" value="1048576"/>
    </bean>

    <bean name="edcrBpaRestService" class="org.egov.edcr.service.EdcrBpaRestService"/>

</beans>