{
  "moduleName": "employee_module",
  "description": "E-Waste employee approval workflow",
  "baseUrl": "${selected.url}",
  "instructions": [
    {
      "stepName": "Enter username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 300
    },
    {
      "stepName": "Enter password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 300
    },
    {
      "stepName": "Select city from dropdown",
      "locatorStrategy": "CSS",
      "locatorValue": "input.employee-select-wrap--elipses",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Continue button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class, 'submit-bar') and .//header[text()='Continue']]",
      "action": "CLICK",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Navigate to E-Waste inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//span[normalize-space()='E WASTE MANAGEMENT']/ancestor::div[contains(@class,'employeeCustomCard')]//a",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Enter request ID in search",
      "locatorStrategy": "XPATH",
      "locatorValue": "//h4[contains(text(),'Request ID')]/following::input[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click search button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Click Take Action button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class, 'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Verify Product option",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Verify Product']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter verification comment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//textarea[@name='comments']",
      "action": "TYPE",
      "inputValue": "Product verified",
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Verify Product button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Verify Product']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Take Action for pickup",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class, 'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Send Pickup Alert",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Send Pickup Alert']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Set pickup date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "inputValue": "0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter pickup comment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//textarea[@name='comments']",
      "action": "TYPE",
      "inputValue": "Pickup Alert",
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Send Pickup Alert button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Send Pickup Alert']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Take Action for complete",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class, 'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Complete Request",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Complete Request']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter transaction ID",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@name='transactionId']",
      "action": "TYPE",
      "inputValue": "${transaction.id}",
      "dynamicSleep": 300
    },
    {
      "stepName": "Enter final amount",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@name='finalAmount']",
      "action": "TYPE",
      "inputValue": "${final.amount}",
      "dynamicSleep": 300
    },
    {
      "stepName": "Enter completion comment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//textarea[@name='comments']",
      "action": "TYPE",
      "inputValue": "Completed",
      "dynamicSleep": 500
    },
    {
      "stepName": "Click Complete Request button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Complete request']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    }
  ]
}
