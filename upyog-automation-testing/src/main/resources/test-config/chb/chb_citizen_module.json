{
  "moduleName": "chb_citizen_module",
  "description": "Community hall booking full citizen flow with payment",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Enter Mobile Number",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${selected.mobile}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Accept Terms",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox'].form-field",
      "action": "CLICK_JS",
      "dynamicSleep": 500
    },

    {
      "stepName": "Click Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter OTP",
      "locatorStrategy": "CSS",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap.reverse-radio-selection-wrapper div",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city.mohali}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Continue')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open CHB Home",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/chb-home']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Search Hall",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/chb/bookHall']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Hall",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Open Calendar",
      "locatorStrategy": "CSS",
      "locatorValue": "svg.calendar-icon",
      "action": "CLICK",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Three Days",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Three Days')]",
      "action": "CLICK",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Booking Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Hall",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[contains(text(),'Search')]]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select First Site Only",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='checkbox'])[2]",
      "action": "CLICK",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Book",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Book')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Fill New Details",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Fill New Details']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Info Page Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Applicant Name",
      "locatorStrategy": "NAME",
      "locatorValue": "applicantName",
      "action": "TYPE",
      "inputValue": "Arpit Rao",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Email",
      "locatorStrategy": "NAME",
      "locatorValue": "emailId",
      "action": "TYPE",
      "inputValue": "arpit@gmail.com",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Mobile",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "9999999999",
      "dynamicSleep": 500
    },
    {
      "stepName": "Applicant Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Hall Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Purpose",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Purpose Description",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "Community Meeting",
      "dynamicSleep": 500
    },
    {
      "stepName": "Additional Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Pincode",
      "locatorStrategy": "NAME",
      "locatorValue": "pincode",
      "action": "TYPE",
      "inputValue": "143001",
      "dynamicSleep": 500
    },
    {
      "stepName": "Street Name",
      "locatorStrategy": "NAME",
      "locatorValue": "streetName",
      "action": "TYPE",
      "inputValue": "Test Street",
      "dynamicSleep": 500
    },
    {
      "stepName": "House Number",
      "locatorStrategy": "NAME",
      "locatorValue": "houseNo",
      "action": "TYPE",
      "inputValue": "420",
      "dynamicSleep": 500
    },
    {
      "stepName": "Landmark",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "Test Land Registration",
      "dynamicSleep": 500
    },
    {
      "stepName": "Address Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Account Number",
      "locatorStrategy": "NAME",
      "locatorValue": "accountNumber",
      "action": "TYPE",
      "inputValue": "1168977476837687",
      "dynamicSleep": 500
    },
    {
      "stepName": "Confirm Account Number",
      "locatorStrategy": "NAME",
      "locatorValue": "confirmAccountNumber",
      "action": "TYPE",
      "inputValue": "1168977476837687",
      "dynamicSleep": 500
    },
    {
      "stepName": "IFSC Code",
      "locatorStrategy": "NAME",
      "locatorValue": "ifscCode",
      "action": "TYPE",
      "inputValue": "ICIC0000001",
      "dynamicSleep": 500
    },
    {
      "stepName": "Account Holder",
      "locatorStrategy": "NAME",
      "locatorValue": "accountHolderName",
      "action": "TYPE",
      "inputValue": "Arpit Rao",
      "dynamicSleep": 500
    },
    {
      "stepName": "Bank Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Bank Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Bank Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Address Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Address Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[2]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Identity Proof Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Identity Proof",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='file'])[3]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Documents Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Next']]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Accept Declaration",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CHECK_LAST_CHECKBOX",
      "dynamicSleep": 500
    },
    {
      "stepName": "Submit Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Submit']]",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    },
    {
      "stepName": "Click Make Payment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'make payment')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click Proceed To Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'proceed to pay')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click UPYOG Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action": "CLICK_JS",
      "dynamicSleep": 4000
    },
    {
      "stepName": "Switch Payment Window",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "SWITCH_WINDOW",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click Net Banking",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Net Banking')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select ICICI",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'icici')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click Gateway Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'pay')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Click Success",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Success')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },
    {
      "stepName": "Switch Back To UPYOG",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "SWITCH_WINDOW",
      "dynamicSleep": 2000
    }

  ]
}