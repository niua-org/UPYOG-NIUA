{
  "moduleName":"pet_employee_module",
  "description": "Pet Registration Employee flow",

  "baseUrl": "${employee.base.url}",

  "instructions":[


    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${pet.login.username}"
    },
    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${pet.login.password}"
    },
    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },
    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Open Pet Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/employee/ptr/petservice/inbox']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Enter Application Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[3]",
      "action": "TYPE",
      "inputValue": "${pet.application.number}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Search",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Take Action Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click VERIFY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'menu-wrap')]//p[normalize-space()='VERIFY']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Verify Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated verification comment."
    },
    {
      "stepName":"Click Verify Popup",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'selector-button-primary') and .//h2[normalize-space()='Verify']]",
      "action":"CLICK_JS"
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click APPROVE",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'menu-wrap')]//p[normalize-space()='APPROVE']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated approval comment."
    },
    {
      "stepName":"Click Approve Popup",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'selector-button-primary') and .//h2[normalize-space()='Approve']]",
      "action":"CLICK_JS"
    },




    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click PAY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'menu-wrap')]//p[normalize-space()='PAY']",
      "action":"CLICK_JS"
    },




    {
      "stepName":"Enter Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9847584944"
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Collect Payment')]",
      "action":"CLICK_JS"
    },




    {
      "stepName":"Download Receipt 1",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid:nth-of-type(1) svg",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Download Receipt 2",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid:nth-of-type(2) svg",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Download Receipt 3",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid:nth-of-type(3) svg",
      "action":"CLICK_JS"
    }

  ]
}