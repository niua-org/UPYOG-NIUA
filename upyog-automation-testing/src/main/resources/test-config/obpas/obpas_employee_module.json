{
  "moduleName":"obpas_employee",

  "instructions":[


    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${obpas.login.username}"
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${obpas.login.password}"
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Continue",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open OBPS Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'OBPS Inbox')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Search Application",
      "locatorStrategy":"NAME",
      "locatorValue":"applicationNo",
      "action":"TYPE",
      "inputValue":"${obpas.application.number}"
    },

    {
      "stepName":"Click Search",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(text(),'${obpas.application.number}')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Take Action",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'TAKE ACTION')]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Forward",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='FORWARD']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Forwarded"
    },

    {
      "stepName":"Verify Forward",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'VERIFY AND FORWARD')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Go Home",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'Go back to home page')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open OBPS Inbox Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'OBPS Inbox')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Search Again",
      "locatorStrategy":"NAME",
      "locatorValue":"applicationNo",
      "action":"TYPE",
      "inputValue":"${obpas.application.number}"
    },

    {
      "stepName":"Search Again Button",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Application Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(text(),'${obpas.application.number}')]",
      "action":"CLICK_JS"
    },



