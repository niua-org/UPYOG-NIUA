{
  "moduleName": "obpas_citizen_module",
  "description": "OBPAS full citizen architect flow with payment",

  "baseUrl": "${selected.url}",

  "instructions": [




    {
      "stepName": "Enter Architect Mobile",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${architect.mobile.number}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Accept Terms",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox'].form-field",
      "action": "CLICK_JS",
      "dynamicSleep": 500
    },

    {
      "stepName": "Click Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter OTP",
      "locatorStrategy": "CSS",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap.reverse-radio-selection-wrapper div",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Continue')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Open OBPAS",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/obps-home']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open Architect Login",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/obps/home']",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Plan Scrutiny",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Plan scrutiny for new construction')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Select Scrutiny City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Applicant Name",
      "locatorStrategy": "NAME",
      "locatorValue": "applicantName",
      "action": "TYPE",
      "inputValue": "Arpit Rao",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload DXF",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "0:${document.drawing.dxf}",
      "dynamicSleep": 5000
    },

    {
      "stepName": "Submit Scrutiny",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 10000
    },




    {
      "stepName": "Apply Building Permit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(.,'Apply for Building Plan Permit')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Info Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Basic Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },




    {
      "stepName": "Holding Number",
      "locatorStrategy": "NAME",
      "locatorValue": "holdingNumber",
      "action": "TYPE",
      "inputValue": "Test1234",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Land Registration",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "Test Land Registration",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Plot Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },




    {
      "stepName": "Scrutiny Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },




    {
      "stepName": "Search Property City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Owner Mobile",
      "locatorStrategy": "XPATH",
      "locatorValue": "//h2[contains(.,\"Owner's mobile number\")]/following::input[1]",
      "action": "TYPE",
      "inputValue": "9999999999",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Search Property",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName": "Select Property",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//button[normalize-space()='Select'])[3]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Location Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Owner Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },




    {
      "stepName": "Upload Identity Proof",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "0:${document.identity.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload Address Proof",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "1:${document.address.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload Remaining Documents",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "WAIT",
      "dynamicSleep": 10000
    },

    {
      "stepName": "Document Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Upload Airport NOC",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "0:${document.identity.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload Fire NOC",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "2:${document.identity.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "NOC Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Summary Submit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Submit')]",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    },




    {
      "stepName": "Logout",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Logout')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Citizen Login Again",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "RELOAD_BASE_URL",
      "dynamicSleep": 3000
    },




    {
      "stepName": "Payment Flow",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "WAIT",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Click Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'pay')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName": "Click UPYOG Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action": "CLICK_JS",
      "dynamicSleep": 4000
    },

    {
      "stepName": "Switch Window",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "SWITCH_WINDOW",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Net Banking",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Net Banking')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "ICICI",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'icici')]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Gateway Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'pay')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName": "Success",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Success')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName": "Switch Back",
      "locatorStrategy": "TAGNAME",
      "locatorValue": "body",
      "action": "SWITCH_WINDOW",
      "dynamicSleep": 2000
    }

  ]
}