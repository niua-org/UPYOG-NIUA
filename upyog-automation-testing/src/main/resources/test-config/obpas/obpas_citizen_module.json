{
  "moduleName": "OBPAS_CITIZEN",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Architect Login Mobile",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${selected.mobile}",
      "dynamicSleep": 500
    },

    {
      "stepName": "Accept Terms",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 500
    },

    {
      "stepName": "Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter OTP",
      "locatorStrategy": "CSS",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Continue')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open OBPAS",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/obps-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Architect Login",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/obps/home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Plan Scrutiny",
      "locatorStrategy": "XPATH",
      "locatorValue": "//*[contains(text(),'Plan scrutiny for new construction')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Scrutiny City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Applicant Name",
      "locatorStrategy": "NAME",
      "locatorValue": "applicantName",
      "action": "TYPE",
      "inputValue": "Arpit Rao",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload DXF",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.drawing.dxf}",
      "dynamicSleep": 5000
    },

    {
      "stepName": "Submit Scrutiny",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 10000
    },

    {
      "stepName": "Apply for Building Permit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[.//header[contains(text(),'Apply for Building Plan Permit')]]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },

    {
      "stepName": "Info Page Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Basic Details Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Holding Number",
      "locatorStrategy": "NAME",
      "locatorValue": "holdingNumber",
      "action": "TYPE",
      "inputValue": "Test1234",
      "dynamicSleep": 500
    },

    {
      "stepName": "Land Registration",
      "locatorStrategy": "CSS",
      "locatorValue": "textarea.card-textarea",
      "action": "TYPE",
      "inputValue": "Test Land Registration",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Plot Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Scrutiny Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Search Owner Mobile",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[contains(@class,'employee-card-input')]",
      "action": "TYPE",
      "inputValue": "9999999999",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Search Property",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Select Property",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//button[normalize-space()='Select'])[3]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Location Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Owner Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Upload Identity Proof",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.iDentity.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload Address Proof",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.aDdress.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Documents Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },

    {
      "stepName": "NOC Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },

    {
      "stepName": "Summary Submit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Submit')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    }

  ]
}