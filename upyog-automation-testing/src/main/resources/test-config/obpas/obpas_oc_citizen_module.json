    },



    {
      "stepName":"NOC Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Summary Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Submit')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Citizen Approval",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'APPROVE')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Architect Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Submit')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Make Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'Pay')]",
      "action":"PAYMENT_FLOW"
    },
    {
      "stepName":"Click Make Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'pay')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Click Proceed To Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'proceed')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Click UPYOG Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action":"CLICK_JS",
      "dynamicSleep": 4000
    },

    {
      "stepName":"Switch Payment Window",
      "locatorStrategy":"TAGNAME",
      "locatorValue":"body",
      "action":"SWITCH_WINDOW",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Select Net Banking",
      "locatorStrategy":"XPATH",
