{
  "moduleName":"obpas_oc_create",

  "instructions":[

    {
      "stepName":"Architect Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue":"${architect.mobile.number}"
    },

    {
      "stepName":"Terms Checkbox",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"OBPAS Home",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/obps-home']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Architect Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(text(),'Registered Architect Login')]",
      "action":"CLICK_JS"
    },



