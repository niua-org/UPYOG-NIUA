{
  "moduleName": "cnd_employee_module",
  "description": "CnD employee full UI workflow",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },

    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 500
    },

    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open CnD Inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/cnd/inbox')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Enter Application Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[3]",
      "action": "TYPE",
      "inputValue": "${selected.applicationNumber}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Search",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Click Take Action",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Assign Field Inspector",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Assign Field Inpector']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Select Inspector",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "FI Comment",
      "locatorStrategy": "NAME",
      "locatorValue": "comments",
      "action": "TYPE",
      "inputValue": "Assigned",
      "dynamicSleep": 500
    },
    {
      "stepName": "Submit FI",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='SUBMIT']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Take Action Approve",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Approve",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Approve']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Enter Waste Quantity",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='tel'])[1]",
      "action": "TYPE",
      "inputValue": "10",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Submit Approval",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='Submit']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Go Home",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='Home']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Inbox Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/cnd/inbox')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Search Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[3]",
      "action": "TYPE",
      "inputValue": "${selected.applicationNumber}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Button Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Application Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Take Action Fees",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='TAKE ACTION']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Collect Fees",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Collect Fees']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Payer Name",
      "locatorStrategy": "NAME",
      "locatorValue": "payerName",
      "action": "TYPE",
      "inputValue": "Arpit Rao",
      "dynamicSleep": 500
    },
    {
      "stepName": "Payer Mobile",
      "locatorStrategy": "NAME",
      "locatorValue": "payerMobile",
      "action": "TYPE",
      "inputValue": "9999999999",
      "dynamicSleep": 500
    },
    {
      "stepName": "Receipt Number",
      "locatorStrategy": "NAME",
      "locatorValue": "instrumentNumber",
      "action": "TYPE",
      "inputValue": "GEN123456",
      "dynamicSleep": 500
    },
    {
      "stepName": "Receipt Date",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Collect Payment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='Collect Payment']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Go Home Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[normalize-space()='Go back to home page']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Inbox Third Time",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/cnd/inbox')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Search Third Time",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "selected.applicationNumber",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Third Button",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Third Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Assign Vendor",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Assign Vendor']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Cancel Popup",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'selector-button-border')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Assign Vendor Again",
      "locatorStrategy": "XPATH",
      "locatorValue": "//p[normalize-space()='Assign Vendor']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Vendor",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Set Schedule Date",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Vendor Comment",
      "locatorStrategy": "NAME",
      "locatorValue": "comments",
      "action": "TYPE",
      "inputValue": "Assigned",
      "dynamicSleep": 500
    },
    {
      "stepName": "Submit Vendor",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='SUBMIT']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    }

  ]
}