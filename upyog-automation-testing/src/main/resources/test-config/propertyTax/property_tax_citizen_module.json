    },
    {
      "stepName":"Pincode Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },




    {
      "stepName":"City Radio",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='radio'])[1]",
