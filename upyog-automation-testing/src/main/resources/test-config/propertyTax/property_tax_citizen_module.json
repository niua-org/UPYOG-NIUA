      "locatorValue":"//label[normalize-space()='Single Owner']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Ownership Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Owner Name",
      "locatorStrategy":"NAME",
      "locatorValue":"name",
      "action":"TYPE",
      "inputValue":"Arpit Rao",
      "dynamicSleep":1000
    },


    {
      "stepName":"Gender",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Male']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Mobile Number",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue":"9999999999",
      "dynamicSleep":1000
