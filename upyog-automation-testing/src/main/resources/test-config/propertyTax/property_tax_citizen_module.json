      "action":"TYPE",
      "inputValue":"Ramesh Rao",
      "dynamicSleep":1000
    },

    {
      "stepName":"Relation",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Father']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Email",
      "locatorStrategy":"NAME",
      "locatorValue":"email",
      "action":"TYPE",
      "inputValue":"Asdj@gmail.com",
      "dynamicSleep":1000
    },
    {
      "stepName":"Owner Details Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
    },
    {
      "stepName":"Not Applicable",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Not Applicable']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Special Category Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
    },




    {
      "stepName":"Owner Address Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CHECK_LAST_CHECKBOX",
      "inputValue": null,
      "dynamicSleep":1000
    },

    {
      "stepName":"Owner Address Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
    },
    {
      "stepName":"Identity Proof Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep":1000
    },

    {
      "stepName":"Upload Identity Proof",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Identity Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
    },




    {
      "stepName":"Summary Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CHECK_LAST_CHECKBOX",
      "inputValue": null,
      "dynamicSleep":1000
    },

    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Submit')]",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },

    {
      "stepName":"Proceed Duplicate Popup",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Proceed')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
