      "stepName":"Upload Address Proof",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Documents Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },




    {
