{
  "moduleName": "property_tax_citizen_module",
  "description": "Property Tax citizen registration workflow",
  "baseUrl": "${selected.url}",
  "instructions":[
    {
      "stepName":"Enter Mobile Number",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue": "${selected.mobile}",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Accept Terms",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox'].form-field",
      "action":"CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Next",
      "locatorStrategy":"XPATH",
      "locatorValue": "//button[@type='submit']//header[text()='Next']/..",
      "action":"CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Enter OTP",
      "locatorStrategy": "NAME",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']//header[text()='Next']/..",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.radio-wrap.reverse-radio-selection-wrapper div",
      "action":"SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city}",
      "dynamicSleep": 1500
    },
    {
      "stepName":"Continue",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName":"Open Property Tax Module",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='${module.propertTax.url}']",
      "action":"CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName":"Open Create Property",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/pt/property/new-application/info']",
      "action":"CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },
    {
      "stepName":"Info Page Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Property Type",
      "locatorStrategy": "XPATH",
      "locatorValue": "//label[normalize-space()='${property.type}']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Property Type Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Electricity Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[contains(@placeholder,'electricity')]",
      "action":"TYPE",
      "inputValue":"1234567890",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Electricity Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Structure Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Age Of Property",
      "locatorStrategy":"CSS",
