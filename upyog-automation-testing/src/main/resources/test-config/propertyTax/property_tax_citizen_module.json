      "inputValue":"ABCD1234567890E",
      "dynamicSleep": 1000
    },
    {
      "stepName":"UID Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
