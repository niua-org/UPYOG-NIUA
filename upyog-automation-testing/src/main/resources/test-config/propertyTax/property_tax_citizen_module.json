    },

    {
      "stepName":"Locality Radio",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='radio'])[2]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Address Select Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep":1000
    },




    {
      "stepName":"Street Name",
      "locatorStrategy":"NAME",
      "locatorValue":"street",
      "action":"TYPE",
