    {
      "stepName":"Built Up Area",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE",
      "inputValue":"1100",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Ground Floor Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Skip Location",
      "locatorStrategy":"CSS",
      "locatorValue":"span.card-link.cp",
      "action":"CLICK_JS",
      "dynamicSleep":1500
    },
    {
      "stepName":"Pincode",
      "locatorStrategy":"XPATH",
