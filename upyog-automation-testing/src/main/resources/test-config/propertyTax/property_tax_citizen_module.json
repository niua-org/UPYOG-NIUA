      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Ground Floor Only",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Ground Floor Only']/preceding-sibling::span/input[@type='radio']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Floor Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Ground Floor Usage",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:4",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Occupancy",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:1",
      "dynamicSleep": 1000
