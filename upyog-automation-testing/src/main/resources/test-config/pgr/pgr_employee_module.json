{
  "moduleName":"pgr_employee_module",
  "description": "PGR employee full workflow",

  "baseUrl": "${employee.base.url}",


  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${pgr.login.username}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${pgr.login.password}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Continue",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Grievance Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//span[text()='Grievances']/ancestor::div[contains(@class,'employeeCustomCard')]//*[normalize-space()='Inbox']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Assigned To All",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Assigned to All']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS"
    },

    {
      "stepName":"Enter Grievance ID",
      "locatorStrategy":"NAME",
      "locatorValue":"serviceRequestId",
      "action":"TYPE",
      "inputValue":"${pgr.application.number}"
    },

    {
      "stepName":"Search Complaint",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Assign",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Click Assign Grievance",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Assign Grievance']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Assign Comment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//textarea[@name='comment']",
      "action":"TYPE",
      "inputValue":"Assigned",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Submit Assign",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Resolve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Click Resolve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Resolve']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Resolve Comment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//textarea[@name='comment']",
      "action":"TYPE",
      "inputValue":"Resolved",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Submit Resolve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Resolve']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    }

  ]
}