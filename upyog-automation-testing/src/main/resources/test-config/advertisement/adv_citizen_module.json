{
  "moduleName": "advertisement_citizen_module",
  "description": "Advertisement citizen full UI workflow",
  "baseUrl": "${selected.url}",
  "instructions": [

    {
      "stepName": "Open Advertisement Home",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/ads-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open Advertisement Booking",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/ads/bookad')]",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    },
    {
      "stepName": "Select Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Advertisement Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Location",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:6",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Set From Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Set To Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "1",
      "dynamicSleep": 1000
