      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Locality Dropdown",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 1000
