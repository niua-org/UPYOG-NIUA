{
  "moduleName": "desludging_psso_module",
  "description": "Desludging  full workflow",
  "baseUrl": "${selected.url}",
  "instructions": [
    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Click FSM Inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/fsm/fstp-inbox')]",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Enter Desludging Request Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "//h4[contains(text(),'Desludging Request Number ')]/following::input[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Booking",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Set Hour",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[contains(@name,'hour')]",
      "action":"TYPE",
      "inputValue":"10",
      "dynamicSleep":500
    },
    {
      "stepName":"Set Minute",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[contains(@name,'minute')]",
      "action":"TYPE",
      "inputValue":"30",
      "dynamicSleep":500
    },
    {
      "stepName":"Set AM PM",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'react-time-picker__inputGroup')]",
      "action":"CLICK_JS",
      "dynamicSleep":500
    },
    {
      "stepName": "Enter Septage Dumped",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@name='wasteRecieved']",
      "action": "TYPE",
      "inputValue": "500",
      "dynamicSleep": 1000
    },{
      "stepName":"Take Action",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Take Action')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Submit']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    }
  ]
}