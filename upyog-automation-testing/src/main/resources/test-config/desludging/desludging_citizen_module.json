{
  "moduleName": "desludging_citizen_module",

  "description": "Desludging citizen workflow",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Enter mobile number",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${selected.mobile}",
      "dynamicSleep": 500
    },

    {
      "stepName": "Accept terms",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 500
    },

    {
      "stepName": "Click Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Enter OTP",
      "locatorStrategy": "CSS",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 500
    },

    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },

    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city}",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Continue')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open Desludging module",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Open new application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm/new-application']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Select Service Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:1",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Select Service Sub Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:0",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },

    {
      "stepName": "Search Property Mobile",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[contains(@class,'employee-card-input')]",
      "action": "TYPE",
      "inputValue": "9999999999",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Click Search",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName": "Select Property",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//button[normalize-space()='Select'])[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },

    {
      "stepName": "Select Property Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "Residential",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },

    {
      "stepName": "Select Sub Property Type",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "Independent house",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },

    {
      "stepName": "Skip map",
      "locatorStrategy": "XPATH",
      "locatorValue": "//span[contains(text(),'Skip and Continue')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },

    {
      "stepName": "Enter Pincode",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[contains(@name,'pincode')]",
      "action": "TYPE",
      "inputValue": "143001",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Upload Pit Image",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file']",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.pitPhoto.proof}",
      "dynamicSleep": 2000
    },

    {
      "stepName": "Submit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Submit']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    }

  ]
}