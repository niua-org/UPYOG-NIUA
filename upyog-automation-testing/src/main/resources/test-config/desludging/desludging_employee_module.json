{
  "moduleName": "desludging_employee_module",
  "description": "Desludging employee full workflow",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Click FSM Inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/fsm/inbox')]",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Search Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/fsm/search')]",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName":"Enter Desludging Request Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h4[contains(text(),'Desludging Request Number ')]/following::input[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep":1000
    },
    {
      "stepName":"Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Update Application')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Length",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='number'])[1]",
      "action": "TYPE",
      "inputValue": "10",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Breadth",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='number'])[2]",
      "action": "TYPE",
      "inputValue": "8",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Height",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='number'])[3]",
      "action": "TYPE",
      "inputValue": "6",
      "dynamicSleep": 500
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Update Application')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    }
  ]
}