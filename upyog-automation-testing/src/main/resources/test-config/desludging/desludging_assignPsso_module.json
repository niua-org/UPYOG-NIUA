{
  "moduleName": "desludging_assignPsso_module",
  "description": "Desludging Assign Psso full workflow",
  "baseUrl": "${selected.url}",
  "instructions": [
    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Click FSM Inbox",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/fsm/inbox')]",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Search Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/fsm/search')]",
      "action": "CLICK",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Enter Desludging Request Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "//h4[contains(text(),'Desludging Request Number ')]/following::input[1]",
      "action": "TYPE",
      "inputValue": "${selected.applicationNumber}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Search Booking",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[normalize-space()='Search']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Assign PSSO')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"PSSO Name",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:1",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Set From Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "0"
    },
    {
      "stepName":"Assign PSSO Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Take Action')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Assign Vehicle",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Assign Vehicle']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Assign Vehicle",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Assign Vehicle",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Take Action')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Complete Request ",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Complete Request']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Assign Vehicle",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()=Completed']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    }
  ]
}