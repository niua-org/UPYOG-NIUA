{
  "moduleName": "desludging_citizenPayment_module",
  "description": "Desludging citizen payment workflow",
  "baseUrl": "${selected.url}",
  "instructions": [

    {
      "stepName": "Open Desludging module",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm-home']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open View application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[@href='/upyog-ui/citizen/fsm/my-applications']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Open First Application View",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//button[contains(.,'View')])[1]",
      "action": "CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Make Payment",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Proceed To Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'proceed to pay')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select ICICI",
      "locatorStrategy": "XPATH",
      "locatorValue":"//label[normalize-space()='ICICI']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click UPYOG Pay",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar') and .//header[normalize-space()='Pay']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 4000
    },
      {
        "stepName": "Open Cards Section",
        "locatorStrategy": "ID",
        "locatorValue": "cardAccordionBtn",
        "action": "CLICK",
        "dynamicSleep": 1000
      },
      {
        "stepName": "Enter Name On Card",
        "locatorStrategy": "ID",
        "locatorValue": "nameOnCard",
        "action": "TYPE",
        "inputValue": "Arpit",
        "dynamicSleep": 500
      },
      {
        "stepName": "Enter Card Number",
        "locatorStrategy": "ID",
        "locatorValue": "cardNoMasked",
        "action": "TYPE",
        "inputValue": "4111111111111111",
        "dynamicSleep": 500
      },
      {
        "stepName": "Select Expiry Month",
        "locatorStrategy": "ID",
        "locatorValue": "month",
        "action": "SELECT_BY_VALUE",
        "inputValue": "03",
        "dynamicSleep": 500
      },
      {
        "stepName": "Select Expiry Year",
        "locatorStrategy": "ID",
        "locatorValue": "year",
        "action": "SELECT_BY_VALUE",
        "inputValue": "2033",
        "dynamicSleep": 500
      },
      {
        "stepName": "Enter CVV",
        "locatorStrategy": "ID",
        "locatorValue": "cvv",
        "action": "TYPE",
        "inputValue": "123",
        "dynamicSleep": 500
      },
    {
      "stepName":"Click Pay Now",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@id='payBtn2' and contains(@style,'display: block')]",
      "action":"CLICK_JS",
      "dynamicSleep":5000
    },
    {
      "stepName": "Enter OTP",
      "locatorStrategy": "ID",
      "locatorValue": "otp",
      "action": "TYPE",
      "inputValue": "123456",
      "dynamicSleep": 500
    },
    {
      "stepName": "Verify OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@onclick='cardsubmit()']",
      "action": "CLICK_JS",
      "dynamicSleep": 5000
    }
    ]
}