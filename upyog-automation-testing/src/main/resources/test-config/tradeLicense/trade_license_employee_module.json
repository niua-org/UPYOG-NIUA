{
  "moduleName":"trade_license_employee_module",

  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${app.login.username}"
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${app.login.password}"
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Continue",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Trade License Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/digit-ui/employee/tl/inbox']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Enter Application Number",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE",
      "inputValue":"${tl.application.number}"
    },

    {
      "stepName":"Search Application",
      "locatorStrategy":"CSS",
      "locatorValue":"button.submit-bar.submit-bar-search",
      "action":"CLICK"
    },

    {
      "stepName":"Open Application",
      "locatorStrategy":"LINKTEXT",
      "locatorValue":"${tl.application.number}",
      "action":"CLICK"
    },



    {
      "stepName":"Take Action Verify",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"TAKE ACTION",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Verify",
      "locatorStrategy":"LABELTEXT",
      "locatorValue":"VERIFY",
      "action":"CLICK_ACTION_MENU"
    },

    {
      "stepName":"Verify Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated verification comment"
    },

    {
      "stepName":"Upload Verify Document",
      "locatorStrategy":"ID",
      "locatorValue":"workflow-doc",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.identity.proof}"
    },

    {
      "stepName":"Submit Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[normalize-space()='Verify']/..",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"TAKE ACTION",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Approve",
      "locatorStrategy":"LABELTEXT",
      "locatorValue":"APPROVE",
      "action":"CLICK_ACTION_MENU"
    },

    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated approval comment"
    },

    {
      "stepName":"Upload Approve Document",
      "locatorStrategy":"ID",
      "locatorValue":"workflow-doc",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.identity.proof}"
    },

    {
      "stepName":"Submit Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[normalize-space()='Approve']/..",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"TAKE ACTION",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Pay",
      "locatorStrategy":"LABELTEXT",
      "locatorValue":"PAY",
      "action":"CLICK_ACTION_MENU"
    },



    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9847584944"
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Collect Payment",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Download Receipt 1",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid",
      "action":"CLICK_BY_INDEX",
      "inputValue":"0"
    },

    {
      "stepName":"Download Receipt 2",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid",
      "action":"CLICK_BY_INDEX",
      "inputValue":"1"
    },

    {
      "stepName":"Download Receipt 3",
      "locatorStrategy":"CSS",
      "locatorValue":"div.primary-label-btn.d-grid",
      "action":"CLICK_BY_INDEX",
      "inputValue":"2"
    }

  ]
}