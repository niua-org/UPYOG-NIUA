{
  "moduleName":"trade_license_employee_module",
  "description": "Trade License employee full workflow",

  "baseUrl": "${selected.url}",


  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${selected.username}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${selected.password}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[text()='Continue']]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Open Trade License Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/employee/tl/inbox')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Enter Application Number",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Search Application",
      "locatorStrategy":"CSS",
      "locatorValue":"button.submit-bar.submit-bar-search",
      "action":"CLICK",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='VERIFY AND FORWARD']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Verify Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated verification comment",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Verify Document",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}"
    },

    {
      "stepName":"Submit Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[normalize-space()='Verify and Forward']/..",
      "action":"CLICK_JS"
    },
    {
      "stepName":"Take Action Verify 2",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Verify 2",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='VERIFY AND FORWARD']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Verify Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated verification comment",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Verify Document 2",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action":"UPLOAD_FILE",
      "inputValue":"${document.common.proof}"
    },

    {
      "stepName":"Submit Verify 2",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[normalize-space()='Verify and Forward']/..",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='APPROVE']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Automated approval comment",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Approve Document",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Submit Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[normalize-space()='Approve']/..",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click PAY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='PAY']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9847584944",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Receipt Number",
      "locatorStrategy":"NAME",
      "locatorValue":"instrumentNumber",
      "action":"TYPE",
      "inputValue":"GEN123456",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Receipt Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "inputValue": "0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[.//header[normalize-space()='Collect Payment']]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    }
  ]
}