{
  "moduleName":"water_and_sewerage_citizen_module",

  "instructions":[

    {
      "stepName":"Citizen Mobile Number",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue":"${citizen.mobile.number}"
    },

    {
      "stepName":"Accept Terms",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox'].form-field",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Enter OTP",
      "locatorStrategy":"CSS",
      "locatorValue":"input.input-otp",
      "action":"TYPE_OTP",
      "inputValue":"${test.otp}"
    },

    {
      "stepName":"Submit OTP",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.radio-wrap.reverse-radio-selection-wrapper div",
      "action":"SELECT_RADIO_BY_TEXT",
      "inputValue":"${test.city.name}"
    },

    {
      "stepName":"Continue",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Continue",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Water And Sewerage",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/ws-home']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click New Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/ws/create-application/docs-required']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Property City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Property Mobile Search",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[contains(.,'Mobile number')]/following::input[1]",
      "action":"TYPE",
      "inputValue":"9999999999"
    },

    {
      "stepName":"Search Property",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Property",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//button[normalize-space()='Select'])[1]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Info Page Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Property Details Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Common Connection Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Choose Both Services",
      "locatorStrategy":"LABELTEXT",
      "locatorValue":"Both Water and Sewerage",
      "action":"CLICK_RADIO_BY_LABEL"
    },

    {
      "stepName":"Service Type Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Connection Quantity",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE_BY_INDEX",
      "inputValue":"0:10"
    },

    {
      "stepName":"Pipe Size",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Water Connection Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Water Closets",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE_BY_INDEX",
      "inputValue":"0:6"
    },

    {
      "stepName":"Toilet Seats",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE_BY_INDEX",
      "inputValue":"1:4"
    },

    {
      "stepName":"Sewerage Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Document Type 1",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Upload Identity Proof",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file']",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"0:${document.identity1.proof}"
    },



    {
      "stepName":"Document Type 2",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0"
    },

    {
      "stepName":"Upload Address Proof",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file']",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"1:${document.address1.proof}"
    },



    {
      "stepName":"Document Type 3",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0"
    },

    {
      "stepName":"Upload Electricity Bill",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file']",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"2:${document.electricityBill.proof}"
    },



    {
      "stepName":"Document Type 4",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"3:0"
    },

    {
      "stepName":"Upload Plumber Drawing",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file']",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"3:${document.plumberReportDrawing.proof}"
    },



    {
      "stepName":"Documents Next",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"Next",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Submit Application",
      "locatorStrategy":"HEADERBUTTON",
      "locatorValue":"SUBMIT",
      "action":"CLICK_JS"
    }

  ]
}