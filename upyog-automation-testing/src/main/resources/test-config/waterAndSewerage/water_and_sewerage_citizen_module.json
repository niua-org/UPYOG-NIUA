{
  "moduleName":"water_and_sewerage_citizen_module",
  "description": "Water & Sewerage citizen  flow ",

  "baseUrl": "${selected.url}",
  "instructions":[

    {
      "stepName":"Open Water And Sewerage",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/ws-home']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click New Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/ws/create-application/docs-required']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Property City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Property Mobile Search",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[contains(.,'Mobile number')]/following::input[1]",
      "action":"TYPE",
      "inputValue":"7906413996"
    },

    {
      "stepName":"Search Property",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Property",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//button[normalize-space()='Select'])[1]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Info Page Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Property Details Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Common Connection Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Choose Both Services",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Both Water and Sewerage']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Service Type Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Connection Quantity",
      "locatorStrategy":"CSS",
      "locatorValue":"input.employee-card-input",
      "action":"TYPE",
      "inputValue":"10",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Pipe Size",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Water Connection Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Water Closets",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[contains(@class,'employee-card-input')])[1]",
      "action":"TYPE",
      "inputValue":"10",
      "dynamicSleep":2000
    },
    {
      "stepName":"Toilet Seats",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[contains(@class,'employee-card-input')])[2]",
      "action":"TYPE",
      "inputValue":"3",
      "dynamicSleep":2000
    },

    {
      "stepName":"Sewerage Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Document Type 1",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Identity Proof",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Document Type 2",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Address Proof",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[2]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Document Type 3",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Electricity Bill",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[3]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Document Type 4",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"3:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Upload Plumber Drawing",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[4]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Documents Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@class='submit-bar ' and @type='button'][.//header[text()='SUBMIT']]",
      "action":"CLICK_JS"
    }

  ]
}