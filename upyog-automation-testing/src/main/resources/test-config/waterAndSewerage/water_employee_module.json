{
  "moduleName":"water_employee_module",
  "description": "Water connection employee flow ",

  "baseUrl": "${selected.url}",

  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${selected.username}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${selected.password}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[text()='Continue']]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Open Sewerage Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/ws/water/inbox')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName": "Enter Application Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[1]",
      "action": "TYPE_FROM_STORE",
      "inputValue": "APPLICATION_NO",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Search Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Verify And Forward 1",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Verify And Forward 1",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Verify and Forward']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Comment 1",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Verified and Okay to forward",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Submit Verify And Forward 1",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Verify and Forward']",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },


    {
      "stepName":"Take Action Edit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Edit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Edit']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Number Of Taps",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='number'])[1]",
      "action":"TYPE",
      "inputValue":"12",
      "dynamicSleep":2000
    },

    {
      "stepName":"Connection Size",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep":2000
    },

    {
      "stepName":"Nature of Connection",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep":2000
    },

    {
      "stepName":"Source of Water",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep":2000
    },

    {
      "stepName":"Sub Source of Water ",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"3:1",
      "dynamicSleep":2000
    },
    {
      "stepName":"Connection Size(in inches)",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"4:0",
      "dynamicSleep":2000
    },

    {
      "stepName":"Number Of Taps Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='number'])[2]",
      "action":"TYPE",
      "inputValue":"12",
      "dynamicSleep":2000
    },


    {
      "stepName":"Select Plumber Provided By",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"5:1",
      "dynamicSleep":2000
    },

    {
      "stepName":"Road Cutting Road Type Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"6:0",
      "dynamicSleep":2000
    },

    {
      "stepName":"Area Of Plot",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h2[contains(text(),'Area of Plot')]/following::input[1]",
      "action":"TYPE",
      "inputValue":"250",
      "dynamicSleep":2000
    },




    {
      "stepName":"Upload Evidence 1",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Upload Evidence 2",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[2]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 3000
    },


    {
      "stepName":"Upload Evidence 3",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[3]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Upload Evidence 4",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[4]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 10000
    },
    {
      "stepName":"Submit Edit Page",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'SUBMIT')]",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },
    {
      "stepName":"Submit Edit Page",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'SUBMIT')]",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },
    {
      "stepName":"Take Action Verify And Forward 3",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Verify And Forward 3",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Verify and Forward']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Comment 3",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Verified and Okay to forward",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Submit Verify And Forward 3",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Verify and Forward']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Take Action Approve Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Approve Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Approve Connection']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Approved",
      "dynamicSleep":2000
    },
    {
      "stepName":"Submit Approve Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Approve Connection']",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },
    {
      "stepName":"Take Action Collect",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Collect",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Collect']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9999999999",
      "dynamicSleep":2000
    },

    {
      "stepName":"Receipt Number",
      "locatorStrategy":"NAME",
      "locatorValue":"instrumentNumber",
      "action":"TYPE",
      "inputValue":"GEN123456",
      "dynamicSleep":2000
    },

    {
      "stepName":"Receipt Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "dynamicSleep":2000
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Collect']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Go Back To Home",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Go back to home page')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },


    {
      "stepName":"Open Sewerage Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/ws/sewerage/inbox')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName": "Enter Application Number",
      "locatorStrategy": "XPATH",
      "locatorValue": "(//input[@type='text'])[1]",
      "action": "TYPE",
      "inputValue": "${selected.applicationNumber}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Search Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Collect",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Activate Connection",
      "locatorStrategy":"XPATH",
      "locatorValue":"Activate Connection",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Select Plumber Again",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:1",
      "dynamicSleep":2000
    },

    {
      "stepName":"Connection Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "dynamicSleep":2000
    },

    {
      "stepName":"Activate Connection Submit",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Activate Connection')]",
      "action":"CLICK_JS",
      "dynamicSleep":2000
    }

  ]
}