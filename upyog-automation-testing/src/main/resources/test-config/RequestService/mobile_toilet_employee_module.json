{
  "moduleName":"mobile_toilet_employee_module",
  "description": "Mobile Toilet employee full workflow",

  "baseUrl": "${employee.base.url}",


  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${mt.login.username}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${mt.login.password}",
      "dynamicSleep": 1000

    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[text()='Continue']]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Open Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/wt/mt/my-bookings')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Enter Booking Number",
      "locatorStrategy":"NAME",
      "locatorValue":"bookingNo",
      "action":"TYPE",
      "inputValue":"${mt.application.number}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Approve']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Approved",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Approve Popup Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Approve']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click PAY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='PAY']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9999999999",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Receipt Number",
      "locatorStrategy":"NAME",
      "locatorValue":"instrumentNumber",
      "action":"TYPE",
      "inputValue":"GEN123456",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Receipt Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "inputValue": "0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[.//header[normalize-space()='Collect Payment']]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Go Back To Home",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Go back to home page')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Open Search Booking Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/wt/mt/my-bookings')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Enter Booking Number Again",
      "locatorStrategy":"NAME",
      "locatorValue":"bookingNo",
      "action":"TYPE",
      "inputValue":"${mt.application.number}",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Search Booking Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Assign Vendor",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Click Assign Vendor",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Assign Vendor']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Select Vendor",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Assign Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Assigned",
      "dynamicSleep": 3000
    },

    {
      "stepName":"Assign Vendor Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign Vendor']",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    }

  ]
}