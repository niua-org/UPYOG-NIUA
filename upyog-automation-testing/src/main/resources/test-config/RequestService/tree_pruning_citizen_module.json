{
  "moduleName":"tree_pruning_citizen_module",

  "instructions":[

    {
      "stepName":"Citizen Mobile Number",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue":"${citizen.mobile.number}"
    },

    {
      "stepName":"Accept Terms",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox'].form-field",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Enter OTP",
      "locatorStrategy":"CSS",
      "locatorValue":"input.input-otp",
      "action":"TYPE_OTP",
      "inputValue":"${test.otp}"
    },

    {
      "stepName":"Submit OTP",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.radio-wrap.reverse-radio-selection-wrapper div",
      "action":"SELECT_RADIO_BY_TEXT",
      "inputValue":"${test.city.name}"
    },

    {
      "stepName":"Continue",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/wt-home']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Select Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'CitizenHomeCard')]//a[text()='Select Request Service']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Tree Pruning",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:2"
    },

    {
      "stepName":"Save And Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Info Page Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Click Fill New Details",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Fill New Details')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Applicant Name",
      "locatorStrategy":"NAME",
      "locatorValue":"applicantName",
      "action":"TYPE",
      "inputValue":"Arpit Rao"
    },

    {
      "stepName":"Applicant Email",
      "locatorStrategy":"NAME",
      "locatorValue":"emailId",
      "action":"TYPE",
      "inputValue":"arpit@gmail.com"
    },

    {
      "stepName":"Applicant Mobile Optional",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"OPTIONAL_TYPE",
      "inputValue":"9999999999"
    },

    {
      "stepName":"Applicant Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Address Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"House Number",
      "locatorStrategy":"NAME",
      "locatorValue":"houseNo",
      "action":"TYPE",
      "inputValue":"A-12"
    },

    {
      "stepName":"Street Name",
      "locatorStrategy":"NAME",
      "locatorValue":"streetName",
      "action":"TYPE",
      "inputValue":"Test Street"
    },

    {
      "stepName":"Address Line 1",
      "locatorStrategy":"NAME",
      "locatorValue":"addressline1",
      "action":"OPTIONAL_TYPE",
      "inputValue":"Address Line 1"
    },

    {
      "stepName":"Address Line 2",
      "locatorStrategy":"NAME",
      "locatorValue":"addressline2",
      "action":"OPTIONAL_TYPE",
      "inputValue":"Address Line 2"
    },

    {
      "stepName":"Landmark",
      "locatorStrategy":"NAME",
      "locatorValue":"landmark",
      "action":"TYPE",
      "inputValue":"Near Test Landmark"
    },

    {
      "stepName":"City Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0"
    },

    {
      "stepName":"Locality Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0"
    },

    {
      "stepName":"Pincode",
      "locatorStrategy":"NAME",
      "locatorValue":"pincode",
      "action":"TYPE",
      "inputValue":"110011"
    },

    {
      "stepName":"Address Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Reason Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Geo Tag",
      "locatorStrategy":"CSS",
      "locatorValue":"[class*='location']",
      "action":"OPTIONAL_CLICK"
    },

    {
      "stepName":"Upload Site Photo Request Page",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file'].input-mirror-selector-button",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"0:${document.site.proof}"
    },



    {
      "stepName":"Upload Site Photo Documents",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='file'].input-mirror-selector-button",
      "action":"UPLOAD_FILE_BY_INDEX",
      "inputValue":"0:${document.site.proof}"
    },

    {
      "stepName":"Documents Save And Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Accept Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CHECK_LAST_CHECKBOX"
    },

    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@class='submit-bar ' and @type='button'][.//header[text()='Submit']]",
      "action":"CLICK_JS"
    }

  ]
}