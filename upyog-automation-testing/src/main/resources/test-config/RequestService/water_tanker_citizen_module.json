{
  "moduleName":"water_tanker_citizen_module",
  "description": "Water Tanker citizen workflow",
  "baseUrl": "${selected.url}",

  "instructions":[

    {
      "stepName": "Enter Mobile Number",
      "locatorStrategy": "NAME",
      "locatorValue": "mobileNumber",
      "action": "TYPE",
      "inputValue": "${selected.mobile}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Accept Terms Checkbox",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox'].form-field",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Next After Mobile",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']//header[text()='Next']/..",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Enter OTP",
      "locatorStrategy": "NAME",
      "locatorValue": "input.input-otp",
      "action": "TYPE_OTP",
      "inputValue": "${selected.otp}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Submit OTP",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[@type='submit']//header[text()='Next']/..",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.radio-wrap.reverse-radio-selection-wrapper div",
      "action": "SELECT_RADIO_BY_TEXT",
      "inputValue": "${selected.city}",
      "dynamicSleep": 1500
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Continue')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },

    {
      "stepName":"Open Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/wt-home']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Click Select Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'CitizenHomeCard')]//a[text()='Request Service']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Select Water Tanker",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Save And Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Info Page Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },


    {
      "stepName":"Applicant Name",
      "locatorStrategy":"NAME",
      "locatorValue":"applicantName",
      "action":"TYPE",
      "inputValue":"Arpit Rao",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Applicant Email",
      "locatorStrategy":"NAME",
      "locatorValue":"emailId",
      "action":"TYPE",
      "inputValue":"arpit@gmail.com",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Applicant Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Address Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"House Number",
      "locatorStrategy":"NAME",
      "locatorValue":"houseNo",
      "action":"TYPE",
      "inputValue":"A-12",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Street Name",
      "locatorStrategy":"NAME",
      "locatorValue":"streetName",
      "action":"TYPE",
      "inputValue":"Test Street",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Address Line 1",
      "locatorStrategy":"NAME",
      "locatorValue":"addressLine1",
      "action":"TYPE",
      "inputValue":"Address Line 1",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Address Line 2",
      "locatorStrategy":"NAME",
      "locatorValue":"addressLine2",
      "action":"TYPE",
      "inputValue":"Address Line 2",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Landmark",
      "locatorStrategy":"NAME",
      "locatorValue":"landmark",
      "action":"TYPE",
      "inputValue":"Near Test Landmark",
      "dynamicSleep": 2000
    },

    {
      "stepName":"City Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Locality Dropdown",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Pincode",
      "locatorStrategy":"NAME",
      "locatorValue":"pincode",
      "action":"TYPE",
      "inputValue":"143001",
      "dynamicSleep": 2000
    },

    {
      "stepName":"Address Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Select Tanker Type",
      "locatorStrategy":"XPATH",
      "locatorValue":"//label[normalize-space()='Tanker']/preceding-sibling::span/input[@type='radio']",
      "action": "CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Use Of Water",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000

    },

    {
      "stepName":"Water Quantity",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Tanker Quantity",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Delivery Date",
      "locatorStrategy": "XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "inputValue":"0",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Delivery Time",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='time'])[1]",
      "action":"SET_CUSTOM_TIME",
      "inputValue":"10:30 AM",
      "dynamicSleep":2000
    },

    {
      "stepName":"Description",
      "locatorStrategy":"XPATH",
      "locatorValue":"//textarea[@name='description']",
      "action":"TYPE",
      "inputValue":"Need Water Tanker urgently",
      "dynamicSleep":2000
    },



    {
      "stepName":"Request Details Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Accept Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CHECK_LAST_CHECKBOX"
    },

    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@class='submit-bar ' and @type='button'][.//header[text()='Submit']]",
      "action":"CLICK_JS"
    }

  ]
}