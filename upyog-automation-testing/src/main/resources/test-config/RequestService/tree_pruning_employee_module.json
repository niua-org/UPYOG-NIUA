{
  "moduleName":"tree_pruning_employee_module",
  "description": "Tree Pruning employee full workflow",

  "baseUrl": "${employee.base.url}",

  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${tp.login.username}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${tp.login.password}",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[text()='Continue']]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Open Tree Pruning Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'/wt/tp/inbox')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Enter Booking Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//h4[contains(text(),'Booking No.')]/following::input[1]",
      "action":"TYPE",
      "inputValue":"${tp.application.number}",
      "dynamicSleep":1000
    },

    {
      "stepName":"Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },



    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'TAKE ACTION')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Approve']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Approved",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Approve Popup Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Approve']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Click PAY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='PAY']",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },



    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9999999999",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Receipt Number",
      "locatorStrategy":"NAME",
      "locatorValue":"instrumentNumber",
      "action":"TYPE",
      "inputValue":"GEN123456",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Receipt Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY",
      "inputValue": "0",
      "dynamicSleep": 1000
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[.//header[normalize-space()='Collect Payment']]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    },



    {
      "stepName":"Go Back To Home",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Go back to home page')]",
      "action":"CLICK_JS",
      "dynamicSleep": 3000
    }
  ]
}