{
  "moduleName":"water_tanker_vendor_module",

  "instructions":[

    {
      "stepName":"Vendor Mobile Number",
      "locatorStrategy":"NAME",
      "locatorValue":"mobileNumber",
      "action":"TYPE",
      "inputValue":"${water.vendor.mobile.number}"
    },

    {
      "stepName":"Accept Terms",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox'].form-field",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Enter OTP",
      "locatorStrategy":"CSS",
      "locatorValue":"input.input-otp",
      "action":"TYPE_OTP",
      "inputValue":"${test.otp}"
    },

    {
      "stepName":"Submit OTP",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@type='submit']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.radio-wrap.reverse-radio-selection-wrapper div",
      "action":"SELECT_RADIO_BY_TEXT",
      "inputValue":"${test.city.name}"
    },

    {
      "stepName":"Continue",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Continue')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/wt-home']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Water Tanker Vendor Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'CitizenHomeCard')]//a[text()='Water Tanker Vendor Login']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[contains(@href,'my-bookings')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Enter Booking Number",
      "locatorStrategy":"NAME",
      "locatorValue":"bookingNo",
      "action":"TYPE",
      "inputValue":"${waterTanker.application.number}"
    },

    {
      "stepName":"Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Application",
      "locatorStrategy":"LINKTEXT",
      "locatorValue":"${waterTanker.application.number}",
      "action":"CLICK"
    },



    {
      "stepName":"Take Action",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Assign Vehicle Driver",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Assign Vehicle Driver']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Vehicle",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Vehicle Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='text']",
      "action":"TYPE_REACT",
      "inputValue":"PN 45 HU 8485"
    },

    {
      "stepName":"Assign Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Assigned"
    },

    {
      "stepName":"Assign Vehicle Driver Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign Vehicle Driver']",
      "action":"CLICK_JS"
    }

  ]
}