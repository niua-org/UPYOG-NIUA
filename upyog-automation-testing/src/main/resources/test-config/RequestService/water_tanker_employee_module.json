{
  "moduleName":"water_tanker_employee_module",

  "instructions":[

    {
      "stepName":"Employee Username",
      "locatorStrategy":"NAME",
      "locatorValue":"username",
      "action":"TYPE",
      "inputValue":"${wt.login.username}"
    },

    {
      "stepName":"Employee Password",
      "locatorStrategy":"NAME",
      "locatorValue":"password",
      "action":"TYPE",
      "inputValue":"${wt.login.password}"
    },

    {
      "stepName":"Select City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0"
    },

    {
      "stepName":"Continue Login",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[text()='Continue']]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Water Tanker Inbox",
      "locatorStrategy":"XPATH",
      "locatorValue":"//span[text()='Water Tanker']/ancestor::div[contains(@class,'employeeCustomCard')]//*[normalize-space()='Inbox']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Enter Booking Number",
      "locatorStrategy":"NAME",
      "locatorValue":"bookingNo",
      "action":"TYPE",
      "inputValue":"${waterTanker.application.number}"
    },

    {
      "stepName":"Search Booking",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Application",
      "locatorStrategy":"LINKTEXT",
      "locatorValue":"${waterTanker.application.number}",
      "action":"CLICK"
    },



    {
      "stepName":"Take Action Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Approve",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Approve']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Approve Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Approved"
    },

    {
      "stepName":"Approve Popup Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Approve']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Take Action Pay",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click PAY",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='PAY']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Payer Mobile",
      "locatorStrategy":"NAME",
      "locatorValue":"payerMobile",
      "action":"TYPE",
      "inputValue":"9999999999"
    },

    {
      "stepName":"Receipt Number",
      "locatorStrategy":"NAME",
      "locatorValue":"instrumentNumber",
      "action":"TYPE",
      "inputValue":"GEN123456"
    },

    {
      "stepName":"Receipt Date",
      "locatorStrategy":"XPATH",
      "locatorValue":"//input[@type='date']",
      "action":"SET_DATE_TODAY"
    },

    {
      "stepName":"Collect Payment",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[.//header[normalize-space()='Collect Payment']]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Go Back To Home Page",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='Go back to home page']]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Open Water Tanker Inbox Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//span[text()='Water Tanker']/ancestor::div[contains(@class,'employeeCustomCard')]//*[normalize-space()='Inbox']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Enter Booking Number Again",
      "locatorStrategy":"NAME",
      "locatorValue":"bookingNo",
      "action":"TYPE",
      "inputValue":"${waterTanker.application.number}"
    },

    {
      "stepName":"Search Booking Again",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Open Application Again",
      "locatorStrategy":"LINKTEXT",
      "locatorValue":"${waterTanker.application.number}",
      "action":"CLICK"
    },



    {
      "stepName":"Take Action Assign Vendor",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(@class,'submit-bar') and .//header[normalize-space()='TAKE ACTION']]",
      "action":"CLICK_JS"
    },

    {
      "stepName":"Click Assign Vendor",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Assign Vendor']",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Select Vendor",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:2"
    },

    {
      "stepName":"Assign Comment",
      "locatorStrategy":"NAME",
      "locatorValue":"comments",
      "action":"TYPE",
      "inputValue":"Assigned"
    },

    {
      "stepName":"Assign Vendor Submit",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Assign Vendor']",
      "action":"CLICK_JS"
    }

  ]
}