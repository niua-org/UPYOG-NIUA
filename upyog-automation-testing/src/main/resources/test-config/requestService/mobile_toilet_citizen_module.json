{
  "moduleName":"mobile_toilet_citizen_module",
  "description": "Mobile Toilet citizen workflow",
  "baseUrl": "${selected.url}",

  "instructions":[


    {
      "stepName":"Open Request Service Module",
      "locatorStrategy":"XPATH",
      "locatorValue":"//a[@href='/upyog-ui/citizen/wt-home']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Click Select Request Service",
      "locatorStrategy":"XPATH",
      "locatorValue":"//div[contains(@class,'CitizenHomeCard')]//a[text()='Select Request Service']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Select Mobile Toilet Service",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:1",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Save And Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Info Page Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Handle New Details Popup",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Fill New Details')]",
      "action":"OPTIONAL_CLICK_JS",
      "dynamicSleep":1000
    },
    {
      "stepName":"Applicant Name",
      "locatorStrategy":"NAME",
      "locatorValue":"applicantName",
      "action":"TYPE",
      "inputValue":"Arpit Rao",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Email",
      "locatorStrategy":"NAME",
      "locatorValue":"emailId",
      "action":"TYPE",
      "inputValue":"arpit@gmail.com",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Applicant Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Address Type",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:0",
      "dynamicSleep": 2000
    },
    {
      "stepName":"House Number",
      "locatorStrategy":"NAME",
      "locatorValue":"houseNo",
      "action":"TYPE",
      "inputValue":"A-12",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Street Name",
      "locatorStrategy":"NAME",
      "locatorValue":"streetName",
      "action":"TYPE",
      "inputValue":"Test Street",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Address Line 1",
      "locatorStrategy":"NAME",
      "locatorValue":"addressLine1",
      "action":"TYPE",
      "inputValue":"123 Main Street",
      "dynamicSleep":2000
    },
    {
      "stepName":"Address Line 2",
      "locatorStrategy":"NAME",
      "locatorValue":"addressLine2",
      "action":"TYPE",
      "inputValue":"Near Park",
      "dynamicSleep":2000
    },
    {
      "stepName":"Landmark",
      "locatorStrategy":"NAME",
      "locatorValue":"landmark",
      "action":"TYPE",
      "inputValue":"Near Test Landmark",
      "dynamicSleep": 2000
    },
    {
      "stepName":"City",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"1:0",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Locality",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"2:0",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Pincode",
      "locatorStrategy":"NAME",
      "locatorValue":"pincode",
      "action":"TYPE",
      "inputValue":"143001",
      "dynamicSleep": 2000
    },
    {
      "stepName":"Address Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },



    {
      "stepName":"Number Of Mobile Toilets",
      "locatorStrategy":"CSS",
      "locatorValue":"div.select svg.cp",
      "action":"SELECT_DROPDOWN_BY_INDEX",
      "inputValue":"0:5"
    },

    {
      "stepName": "Set From Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "0"
    },
    {
      "stepName": "Set To Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "1"
    },
    {
      "stepName":"From Time",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='time'])[1]",
      "action":"SET_CUSTOM_TIME",
      "inputValue":"10:30 AM",
      "dynamicSleep":2000
    },
    {
      "stepName":"To Time",
      "locatorStrategy":"XPATH",
      "locatorValue":"(//input[@type='time'])[2]",
      "action":"SET_CUSTOM_TIME",
      "inputValue":"11:30 PM",
      "dynamicSleep":2000
    },

    {
      "stepName":"Special Request",
      "locatorStrategy":"XPATH",
      "locatorValue":"//textarea[contains(@placeholder,'Special Request')]",
      "action":"TYPE",
      "inputValue":"Need mobile toilet service urgently",
      "dynamicSleep":2000
    },
    {
      "stepName":"Request Details Next",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Save & Next')]",
      "action":"CLICK_JS"
    },



    {
      "stepName":"Accept Declaration",
      "locatorStrategy":"CSS",
      "locatorValue":"input[type='checkbox']",
      "action":"CHECK_LAST_CHECKBOX"
    },

    {
      "stepName":"Submit Application",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[@class='submit-bar ' and @type='button'][.//header[text()='Submit']]",
      "action":"CLICK_JS"
    }

  ]
}