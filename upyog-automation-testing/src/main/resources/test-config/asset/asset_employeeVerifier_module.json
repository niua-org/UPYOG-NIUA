{
  "moduleName": "asset_employee_module",
  "description": "Asset employee full UI workflow",
  "baseUrl": "${selected.url}",
  "instructions": [
    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${selected.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Register Asset",
      "locatorStrategy": "XPATH",
      "locatorValue": "//a[contains(@href,'/assetv2/assetservice/inbox')]",
      "action": "CLICK_JS",
      "dynamicSleep": 3000
    },
    {
      "stepName": "Enter Asset Unique ID",
      "locatorStrategy": "XPATH",
      "locatorValue": "//h4[contains(text(),'Asset Unique ID')]/following::input[1]",
      "action": "TYPE",
      "inputValue": "${selected.applicationNumber}",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Search Complaint",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Search']",
      "action":"CLICK_JS"
    },
    {
      "stepName": "Open Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//table//a[1]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName":"Take Action",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[contains(.,'Take Action')]",
      "action":"CLICK_JS",
      "dynamicSleep": 1000
    },
    {
      "stepName":"Click Verify",
      "locatorStrategy":"XPATH",
      "locatorValue":"//p[normalize-space()='Verify']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    },
    {
      "stepName": "Verify Comment",
      "locatorStrategy": "NAME",
      "locatorValue": "comments",
      "action": "TYPE",
      "inputValue": "Verified",
      "dynamicSleep": 500
    },
    {
      "stepName":"Verify Asset",
      "locatorStrategy":"XPATH",
      "locatorValue":"//button[normalize-space()='Verify']",
      "action":"CLICK_JS",
      "dynamicSleep": 2000
    }
  ]
}