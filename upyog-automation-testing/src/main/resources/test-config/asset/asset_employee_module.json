{
  "moduleName": "asset_employee_module",
  "description": "Asset employee full UI workflow",

  "baseUrl": "${employee.base.url}",

  "instructions": [

    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${employee.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue": "${employee.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Register Asset",
      "locatorStrategy": "XPATH",
      "locatorValue": "//span[text()='Asset MCD']/ancestor::div[contains(@class,'employeeCustomCard')]//*[normalize-space()='Register Asset']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select Financial Year",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Department",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:34",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Parent Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:4",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "3:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Asset Name",
      "locatorStrategy": "INDEX",
      "locatorValue": "4",
      "action": "TYPE_BY_INDEX",
      "inputValue": "MacBook",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Acquisition Mode",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "4:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Coordinates",
      "locatorStrategy": "INDEX",
      "locatorValue": "7",
      "action": "TYPE_BY_INDEX",
      "inputValue": "28.590086610421395,77.2256714858255",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Door Number",
      "locatorStrategy": "INDEX",
      "locatorValue": "8",
      "action": "TYPE_BY_INDEX",
      "inputValue": "21",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Address Line 1",
      "locatorStrategy": "INDEX",
      "locatorValue": "9",
      "action": "TYPE_BY_INDEX",
      "inputValue": "Test Line 1",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Address Line 2",
      "locatorStrategy": "INDEX",
      "locatorValue": "10",
      "action": "TYPE_BY_INDEX",
      "inputValue": "Test Line 2",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Pincode",
      "locatorStrategy": "LABEL",
      "locatorValue": "Pincode",
      "action": "TYPE_BY_LABEL",
      "inputValue": "143001",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Locality",
      "locatorStrategy": "LABEL",
      "locatorValue": "Locality",
      "action": "SELECT_DROPDOWN_BY_LABEL",
      "inputValue": "Main Road Abadpura",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Set Purchase Date",
      "locatorStrategy": "LABEL",
      "locatorValue": "Purchase Date",
      "action": "TYPE_DATE_BY_LABEL",
      "inputValue": "20/02/2024",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Purchase Order Number",
      "locatorStrategy": "LABEL",
      "locatorValue": "Purchase Order Number",
      "action": "TYPE_BY_LABEL",
      "inputValue": "PO123",
      "dynamicSleep": 500
    },
    {
      "stepName": "Source Of Finance",
      "locatorStrategy": "LABEL",
      "locatorValue": "Source of Finance",
      "action": "SELECT_DROPDOWN_BY_LABEL",
      "inputValue": "Municipal Funds",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Purchase Cost",
      "locatorStrategy": "LABEL",
      "locatorValue": "Purchase Cost",
      "action": "TYPE_BY_LABEL",
      "inputValue": "400000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Acquisition Cost",
      "locatorStrategy": "LABEL",
      "locatorValue": "Acquisition Cost",
      "action": "TYPE_BY_LABEL",
      "inputValue": "400000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Market Value Evaluation",
      "locatorStrategy": "LABEL",
      "locatorValue": "Market value as per the Evaluation",
      "action": "TYPE_BY_LABEL",
      "inputValue": "300000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Market Value Circle Rate",
      "locatorStrategy": "LABEL",
      "locatorValue": "Market value as per the Circle rate",
      "action": "TYPE_BY_LABEL",
      "inputValue": "300000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Invoice Date",
      "locatorStrategy": "LABEL",
      "locatorValue": "Invoice Date",
      "action": "TYPE_DATE_BY_LABEL",
      "inputValue": "28/02/2024",
      "dynamicSleep": 500
    },
    {
      "stepName": "Invoice Number",
      "locatorStrategy": "LABEL",
      "locatorValue": "Invoice Number",
      "action": "TYPE_BY_LABEL",
      "inputValue": "INV123",
      "dynamicSleep": 500
    },
    {
      "stepName": "Life Of Asset",
      "locatorStrategy": "LABEL",
      "locatorValue": "Life of Asset",
      "action": "TYPE_BY_LABEL",
      "inputValue": "10",
      "dynamicSleep": 500
    },
    {
      "stepName": "Upload Asset Document 1",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file'].input-mirror-selector-button",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "0:${document.asset.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Asset Document 2",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file'].input-mirror-selector-button",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "1:${document.asset1.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Asset Document 3",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='file'].input-mirror-selector-button",
      "action": "UPLOAD_FILE_BY_INDEX",
      "inputValue": "3:${document.asset2.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Accept Declaration",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CHECK_LAST_CHECKBOX",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Submit Asset Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Submit Grievance']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    }

  ]
}