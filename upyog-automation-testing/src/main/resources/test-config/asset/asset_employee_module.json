{
  "moduleName": "asset_employee_module",
  "description": "Asset employee full UI workflow",

  "baseUrl": "${selected.url}",

  "instructions": [

    {
      "stepName": "Enter Username",
      "locatorStrategy": "NAME",
      "locatorValue": "username",
      "action": "TYPE",
      "inputValue": "${selected.username}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Password",
      "locatorStrategy": "NAME",
      "locatorValue": "password",
      "action": "TYPE",
      "inputValue":"${selected.password}",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Employee City",
      "locatorStrategy": "CSS",
      "locatorValue": "div.select svg",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Continue",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(@class,'submit-bar')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Open Register Asset",
      "locatorStrategy": "XPATH",
      "locatorValue": "//span[text()='Asset MCD']/ancestor::div[contains(@class,'employeeCustomCard')]//*[normalize-space()='Register Asset']",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 3000
    },
    {
      "stepName": "Select Financial Year",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "0:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Department",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "1:34",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Parent Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "2:4",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Category",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "3:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Asset Name",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@name='AssetName']",
      "action": "TYPE",
      "inputValue": "MacBook",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Select Acquisition Mode",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "4:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Coordinates",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[contains(@placeholder,'Enter Manually')]",
      "action": "TYPE",
      "inputValue": "28.590086610421395,77.2256714858255",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Enter Plot No",
      "locatorStrategy": "LABEL",
      "locatorValue": "Plot No.",
      "action": "TYPE_BY_LABEL",
      "inputValue": "21",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Address Line 1",
      "locatorStrategy": "LABEL",
      "locatorValue": "Address Line 1",
      "action": "TYPE_BY_LABEL",
      "inputValue": "Test Address Line 1",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Address Line 2",
      "locatorStrategy": "LABEL",
      "locatorValue": "Address Line 2",
      "action": "TYPE_BY_LABEL",
      "inputValue": "Test Address Line 2",
      "dynamicSleep": 500
    },
    {
      "stepName": "Enter Pincode",
      "locatorStrategy": "LABEL",
      "locatorValue": "Pincode",
      "action": "TYPE_BY_LABEL",
      "inputValue": "143001",
      "dynamicSleep": 500
    },
    {
      "stepName": "Select Locality",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "6:1",
      "dynamicSleep": 1000
    },
    {
      "stepName": "From Date",
      "locatorStrategy": "XPATH",
      "locatorValue": "//input[@type='date']",
      "action": "SET_DATE_TEXT",
      "inputValue": "0:02-09-2000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Purchase Order Number",
      "locatorStrategy": "LABEL",
      "locatorValue": "Purchase Order Number",
      "action": "TYPE_BY_LABEL",
      "inputValue": "PO123",
      "dynamicSleep": 500
    },
    {
      "stepName": "Source Of Finance",
      "locatorStrategy": "CSS",
      "locatorValue": "div.employee-select-wrap svg.cp",
      "action": "SELECT_DROPDOWN_BY_INDEX",
      "inputValue": "7:0",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Purchase Cost",
      "locatorStrategy": "LABEL",
      "locatorValue": "Purchase Cost",
      "action": "TYPE_BY_LABEL",
      "inputValue": "400000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Acquisition Cost",
      "locatorStrategy": "LABEL",
      "locatorValue": "Acquisition Cost",
      "action": "TYPE_BY_LABEL",
      "inputValue": "400000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Market Value Evaluation",
      "locatorStrategy": "LABEL",
      "locatorValue": "Market value as per the Evaluation",
      "action": "TYPE_BY_LABEL",
      "inputValue": "300000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Market Value Circle Rate",
      "locatorStrategy": "LABEL",
      "locatorValue": "Market value as per the Circle rate",
      "action": "TYPE_BY_LABEL",
      "inputValue": "300000",
      "dynamicSleep": 500
    },
    {
      "stepName": "Set From Date",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='date']",
      "action": "SET_DATE_TODAY",
      "inputValue": "0"
    },
    {
      "stepName": "Invoice Number",
      "locatorStrategy": "LABEL",
      "locatorValue": "Invoice Number",
      "action": "TYPE_BY_LABEL",
      "inputValue": "INV123",
      "dynamicSleep": 500
    },
    {
      "stepName": "Life Of Asset",
      "locatorStrategy": "LABEL",
      "locatorValue": "Life of Asset",
      "action": "TYPE_BY_LABEL",
      "inputValue": "10",
      "dynamicSleep": 500
    },
    {
      "stepName": "Upload Asset Document 1",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[1]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Asset Document 2",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[2]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Upload Asset Document 3",
      "locatorStrategy": "XPATH",
      "locatorValue":"(//input[@type='file'])[3]",
      "action": "UPLOAD_FILE",
      "inputValue": "${document.common.proof}",
      "dynamicSleep": 1000
    },
    {
      "stepName": "Click Next",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[contains(.,'Next')]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 2000
    },
    {
      "stepName": "Accept Declaration",
      "locatorStrategy": "CSS",
      "locatorValue": "input[type='checkbox']",
      "action": "CHECK_LAST_CHECKBOX",
      "inputValue": null,
      "dynamicSleep": 1000
    },
    {
      "stepName": "Submit Asset Application",
      "locatorStrategy": "XPATH",
      "locatorValue": "//button[.//header[text()='Submit']]",
      "action": "CLICK_JS",
      "inputValue": null,
      "dynamicSleep": 5000
    },
    {
      "stepName":"Capture Application Number",
      "locatorStrategy":"XPATH",
      "locatorValue":"//*[contains(text(),'Application No') or contains(text(),'Application Number')]/following-sibling::*[1]",
      "action":"CAPTURE_TEXT",
      "inputValue":"APPLICATION_NO",
      "dynamicSleep":3000
    }

  ]
}